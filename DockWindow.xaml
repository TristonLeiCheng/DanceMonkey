<Window x:Class="DesktopAssistant.DockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="320"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="False"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <SolidColorBrush x:Key="DockThemeCardBrush" Color="#1A3A5C" Opacity="0.82"/>
        <SolidColorBrush x:Key="DockThemeCardBorderBrush" Color="#50FFFFFF"/>
        <SolidColorBrush x:Key="DockThemePanelBrush" Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeDividerBrush" Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeQuickBtnBrush" Color="#20FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeQuickBtnHoverBrush" Color="#38FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeQuickBtnPressedBrush" Color="#48FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeChipBrush" Color="#20FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeChipHoverBrush" Color="#38FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeChipActiveBrush" Color="#50FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeInputBrush" Color="#25FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeInputFocusBrush" Color="#35FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeSendBtnBrush" Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="DockThemeSendBtnHoverBrush" Color="#30FFFFFF"/>

        <!-- Dock 快捷按钮 -->
        <Style x:Key="DockQuickBtn" TargetType="Button">
            <Setter Property="Width" Value="62"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Background" Value="{DynamicResource DockThemeQuickBtnBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeQuickBtnHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeQuickBtnPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 搜索框 / 笔记输入框（更紧凑） -->
        <Style x:Key="DockInputBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource DockThemeInputBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#80FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeInputFocusBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 外层半透明磨砂玻璃卡片 -->
    <Border x:Name="CardBorder"
            CornerRadius="16"
            Margin="8"
            Padding="0"
            BorderBrush="{DynamicResource DockThemeCardBorderBrush}"
            BorderThickness="1"
            MouseLeftButtonDown="Card_OnMouseLeftButtonDown">
        <Border.Background>
            <DynamicResource ResourceKey="DockThemeCardBrush"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.35" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 标题栏 -->
                <RowDefinition Height="Auto"/>  <!-- 样式内容 -->
            </Grid.RowDefinitions>

            <!-- Row 0: 标题栏 -->
            <Grid Grid.Row="0" Margin="18,12,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Dock.Title}" FontSize="13" FontWeight="SemiBold"
                           Foreground="#D0FFFFFF" VerticalAlignment="Center"/>
                <Button x:Name="ThemeMenuButton" Grid.Column="1" Content="☰" FontSize="13" Foreground="#D0FFFFFF"
                        Width="28" Height="28" Margin="0,0,8,0" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" ToolTip="{DynamicResource Dock.ThemeMenu}" Click="ThemeMenuButton_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeChipHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ThemeMenu">
                            <MenuItem Header="{DynamicResource Dock.StyleMenu}">
                                <MenuItem x:Name="StyleMenuClassic" Header="{DynamicResource Dock.StyleClassic}" IsCheckable="True" Tag="classic" Click="StyleMenuItem_OnClick"/>
                                <MenuItem x:Name="StyleMenuAssistant" Header="{DynamicResource Dock.StyleAssistant}" IsCheckable="True" Tag="assistant" Click="StyleMenuItem_OnClick"/>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{DynamicResource Dock.ThemeSubMenu}">
                                <MenuItem x:Name="ThemeMenuOcean" Header="{DynamicResource Dock.ThemeOcean}" IsCheckable="True" Tag="ocean" Click="ThemeMenuItem_OnClick"/>
                                <MenuItem x:Name="ThemeMenuAurora" Header="{DynamicResource Dock.ThemeAurora}" IsCheckable="True" Tag="aurora" Click="ThemeMenuItem_OnClick"/>
                                <MenuItem x:Name="ThemeMenuSunset" Header="{DynamicResource Dock.ThemeSunset}" IsCheckable="True" Tag="sunset" Click="ThemeMenuItem_OnClick"/>
                                <MenuItem x:Name="ThemeMenuGrape" Header="{DynamicResource Dock.ThemeGrape}" IsCheckable="True" Tag="grape" Click="ThemeMenuItem_OnClick"/>
                                <MenuItem x:Name="ThemeMenuGraphite" Header="{DynamicResource Dock.ThemeGraphite}" IsCheckable="True" Tag="graphite" Click="ThemeMenuItem_OnClick"/>
                                <MenuItem x:Name="ThemeMenuNoirPro" Header="{DynamicResource Dock.ThemeNoirPro}" IsCheckable="True" Tag="noirpro" Click="ThemeMenuItem_OnClick"/>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <!-- 关闭 Dock -->
                <Button Grid.Column="2" Content="✕" FontSize="11" Foreground="#80FFFFFF"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Width="28" Height="28" ToolTip="{DynamicResource Dock.CloseDock}"
                        Click="BtnCloseDock_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#30E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Row 1: 样式内容容器（ClassicLayout / AssistantLayout 二选一显示） -->
            <Grid Grid.Row="1" x:Name="StyleContentHost">

            <!-- ════════════════ 经典面板 ════════════════ -->
            <Grid x:Name="ClassicLayout">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 时间 -->
                    <RowDefinition Height="Auto"/>  <!-- 日期 / 农历 -->
                    <RowDefinition Height="Auto"/>  <!-- 天气 -->
                    <RowDefinition Height="Auto"/>  <!-- 分隔线 -->
                    <RowDefinition Height="Auto"/>  <!-- 快捷按钮 -->
                    <RowDefinition Height="Auto"/>  <!-- 分隔线 -->
                    <RowDefinition Height="Auto"/>  <!-- 模式切换标签 + 输入框 -->
                </Grid.RowDefinitions>

            <!-- Row 1: 时钟 -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="ClockHour" Text="23" FontSize="52" FontWeight="Light"
                               Foreground="White" VerticalAlignment="Bottom"/>
                    <TextBlock Text=" : " FontSize="48" FontWeight="Light" Foreground="#90FFFFFF"
                               VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                    <TextBlock x:Name="ClockMinute" Text="44" FontSize="52" FontWeight="Light"
                               Foreground="White" VerticalAlignment="Bottom"/>
                </StackPanel>
            </StackPanel>

            <!-- Row 2: 日期 / 农历 -->
            <TextBlock Grid.Row="1" x:Name="DateLabel"
                       Text="4月14日  星期一"
                       FontSize="12.5" Foreground="#B0FFFFFF"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>

            <!-- Row 3: 天气 -->
            <Border x:Name="WeatherPanelBorder" Grid.Row="2" Background="{DynamicResource DockThemePanelBrush}" CornerRadius="8" Margin="18,10,18,0" Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="WeatherIcon" Text="☀" FontSize="16" Foreground="#FFD700"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="WeatherText" Text="正在获取天气…" FontSize="12"
                                   Foreground="#C0FFFFFF" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- 城市设置 -->
                    <Button Grid.Column="1" Content="📍" FontSize="11" Foreground="#70FFFFFF"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="24" Height="24" ToolTip="设置天气城市"
                            Click="BtnWeatherCity_OnClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#20FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Row 4: 分隔线 -->
            <Border Grid.Row="3" Height="1" Background="{DynamicResource DockThemeDividerBrush}" Margin="18,12,18,0"/>

            <!-- Row 5: 快捷按钮（两行） -->
            <StackPanel Grid.Row="4" Margin="10,8,10,0">
                <!-- 第一行 -->
                <WrapPanel HorizontalAlignment="Center">
                    <Button Style="{StaticResource DockQuickBtn}" Click="Btn_AiChat_OnClick" ToolTip="{DynamicResource Dock.BtnAiChat}">
                        <StackPanel>
                            <TextBlock Text="💬" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Dock.BtnAiChat}" FontSize="10" Foreground="#C0FFFFFF" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DockQuickBtn}" Click="Btn_Notes_OnClick" ToolTip="{DynamicResource Dock.BtnNotes}">
                        <StackPanel>
                            <TextBlock Text="📝" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Dock.BtnNotes}" FontSize="10" Foreground="#C0FFFFFF" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DockQuickBtn}" Click="Btn_ZenTask_OnClick" ToolTip="{DynamicResource Dock.BtnZenTask}">
                        <StackPanel>
                            <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Dock.BtnZenTask}" FontSize="10" Foreground="#C0FFFFFF" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DockQuickBtn}" Click="Btn_QuickAccess_OnClick" ToolTip="{DynamicResource Dock.BtnQuickAccess}">
                        <StackPanel>
                            <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Dock.BtnQuickAccess}" FontSize="10" Foreground="#C0FFFFFF" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
                <!-- 第二行 -->
                <WrapPanel HorizontalAlignment="Center">
                    <Button Style="{StaticResource DockQuickBtn}" Click="Btn_FileTools_OnClick" ToolTip="{DynamicResource Dock.BtnFileManager}">
                        <StackPanel>
                            <TextBlock Text="📁" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Dock.BtnFileManager}" FontSize="10" Foreground="#C0FFFFFF" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DockQuickBtn}" Click="Btn_Screenshot_OnClick" ToolTip="{DynamicResource Dock.BtnScreenshot}">
                        <StackPanel>
                            <TextBlock Text="📷" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Dock.BtnScreenshot}" FontSize="10" Foreground="#C0FFFFFF" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DockQuickBtn}" Click="Btn_CodexProxy_OnClick" ToolTip="{DynamicResource Dock.BtnCodexProxy}">
                        <StackPanel>
                            <TextBlock Text="🔁" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Dock.BtnCodexProxy}" FontSize="10" Foreground="#C0FFFFFF" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DockQuickBtn}" Click="Btn_Cli_OnClick" ToolTip="{DynamicResource Dock.CliTip}">
                        <StackPanel>
                            <TextBlock Text="⌨" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Dock.BtnCli}" FontSize="10" Foreground="#C0FFFFFF" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>

            <!-- Row 6: 分隔线 -->
            <Border Grid.Row="5" Height="1" Background="{DynamicResource DockThemeDividerBrush}" Margin="18,6,18,0"/>

            <!-- Row 7: 模式切换标签 + 统一输入框 -->
            <StackPanel Grid.Row="6" Margin="14,6,14,12">
                <!-- 模式切换按钮行 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                    <RadioButton x:Name="TabAi" Content="🤖 AI" GroupName="DockTab"
                                 IsChecked="True" Checked="DockTab_Checked"
                                 Foreground="White" FontSize="11.5" Cursor="Hand"
                                 Margin="0,0,4,0">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="bd" Background="{DynamicResource DockThemeChipBrush}" CornerRadius="8"
                                        Padding="12,5" MinWidth="60">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeChipActiveBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeChipHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                    <RadioButton x:Name="TabTask" Content="{DynamicResource Dock.TabTask}" GroupName="DockTab"
                                 Checked="DockTab_Checked"
                                 Foreground="White" FontSize="11.5" Cursor="Hand"
                                 Margin="0,0,4,0">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="bd" Background="{DynamicResource DockThemeChipBrush}" CornerRadius="8"
                                        Padding="12,5" MinWidth="60">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeChipActiveBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeChipHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                    <RadioButton x:Name="TabSearch" Content="🔍 搜索" GroupName="DockTab"
                                 Checked="DockTab_Checked"
                                 Foreground="White" FontSize="11.5" Cursor="Hand"
                                 Margin="0,0,4,0">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="bd" Background="{DynamicResource DockThemeChipBrush}" CornerRadius="8"
                                        Padding="12,5" MinWidth="60">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeChipActiveBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeChipHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                    <RadioButton x:Name="TabLocalSearch" Content="📂 本地" GroupName="DockTab"
                                 Checked="DockTab_Checked"
                                 Foreground="White" FontSize="11.5" Cursor="Hand">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="bd" Background="{DynamicResource DockThemeChipBrush}" CornerRadius="8"
                                        Padding="12,5" MinWidth="60">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeChipActiveBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeChipHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </StackPanel>
                <!-- 统一输入框 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UnifiedInputBox" Grid.Column="0"
                             Style="{StaticResource DockInputBox}"
                             Tag="输入 AI 问题…"
                             GotFocus="InputBox_GotFocus"
                             LostFocus="InputBox_LostFocus"
                             KeyDown="UnifiedInputBox_KeyDown"/>
                    <Button x:Name="UnifiedSendBtn" Grid.Column="1" Content="↵" FontSize="13" Foreground="#90FFFFFF"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="28" Height="28" Margin="3,0,0,0"
                            ToolTip="发送 (Enter)"
                            Click="BtnUnifiedSend_OnClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{DynamicResource DockThemeSendBtnBrush}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeSendBtnHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
            </Grid>
            <!-- ════════════════ /经典面板 ════════════════ -->

            <!-- ════════════════ 桌面助手（紧凑） ════════════════ -->
            <Grid x:Name="AssistantLayout" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 大时钟 -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,18,0,2">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="ClockHourAst" Text="--" FontSize="64" FontWeight="Light"
                                   Foreground="White" VerticalAlignment="Bottom"/>
                        <TextBlock Text=" : " FontSize="60" FontWeight="Light" Foreground="#90FFFFFF"
                                   VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        <TextBlock x:Name="ClockMinuteAst" Text="--" FontSize="64" FontWeight="Light"
                                   Foreground="White" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </StackPanel>

                <!-- 日期 -->
                <TextBlock Grid.Row="1" x:Name="DateLabelAst"
                           Text=""
                           FontSize="12" Foreground="#B0FFFFFF"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>

                <!-- 天气（紧凑） -->
                <Border Grid.Row="2" Background="{DynamicResource DockThemePanelBrush}" CornerRadius="8"
                        Margin="18,12,18,0" Padding="10,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="WeatherIconAst" Text="🌤" FontSize="15"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="WeatherTextAst" Text="—" FontSize="12"
                                   Foreground="#C0FFFFFF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 助手小提示 -->
                <TextBlock Grid.Row="3" Text="⌨  回车询问 AI    ⌘  回车打开全局对话"
                           FontSize="10.5" Foreground="#80FFFFFF"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>

                <!-- 统一输入框 -->
                <Grid Grid.Row="4" Margin="14,10,14,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="AssistantInputBox" Grid.Column="0"
                             Style="{StaticResource DockInputBox}"
                             Tag="问我任何事…"
                             GotFocus="InputBox_GotFocus"
                             LostFocus="InputBox_LostFocus"
                             KeyDown="AssistantInputBox_KeyDown"/>
                    <Button Grid.Column="1" Content="↵" FontSize="13" Foreground="#90FFFFFF"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="28" Height="28" Margin="3,0,0,0"
                            ToolTip="发送 (Enter)"
                            Click="BtnAssistantSend_OnClick">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{DynamicResource DockThemeSendBtnBrush}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource DockThemeSendBtnHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
            <!-- ════════════════ /桌面助手 ════════════════ -->
            </Grid>
        </Grid>
    </Border>
</Window>
