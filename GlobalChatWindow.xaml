<Window x:Class="DesktopAssistant.GlobalChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Icon="{StaticResource AppWindowIcon}"
        Title="DanceMonkey"
        Width="720" Height="312"
        MinWidth="640" MinHeight="280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        AllowDrop="True"
        Drop="Window_OnDrop"
        DragOver="Window_OnDragOver"
        Opacity="0">

    <Window.Resources>
        <!-- ╔═══════ 玻璃感背板渐变 ═══════╗ -->
        <LinearGradientBrush x:Key="GcGlassBg" StartPoint="0,0" EndPoint="0.4,1">
            <GradientStop Color="#FBFCFF" Offset="0"/>
            <GradientStop Color="#F2F4FA" Offset="1"/>
        </LinearGradientBrush>

        <!-- 顶部高光描边 -->
        <LinearGradientBrush x:Key="GcInnerHighlight" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#80FFFFFF" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="0.6"/>
        </LinearGradientBrush>

        <!-- 主色弱渐变（用于发送按钮） -->
        <LinearGradientBrush x:Key="GcAccentGrad" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#5C7DFF" Offset="0"/>
            <GradientStop Color="#4F6EF7" Offset="1"/>
        </LinearGradientBrush>

        <!-- ╔═══════ 标题栏小图标按钮（关闭/最大化） ═══════╗ -->
        <Style x:Key="GcChromeBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9097A8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="999" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0A1024"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1F2A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 关闭按钮：hover 时变红 -->
        <Style x:Key="GcCloseBtn" TargetType="Button" BasedOn="{StaticResource GcChromeBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="999" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 标题栏次要按钮：存笔记 / 清空 -->
        <Style x:Key="GcTitleSubtleBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5B6478"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="999" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#EBEEF5"/>
                                <Setter Property="Foreground" Value="#1F2937"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ╔═══════ Segmented 模式按钮（透明底，由轨道 + 滑动胶囊承担圆角） ═══════╗ -->
        <Style x:Key="GcSegBtnBase" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            选中/未选中样式：白底+阴影由独立浮动的 SegmentIndicator 提供，
            按钮本身只负责文字颜色与 hover 反馈，避免在切换瞬间出现"双胶囊"。
        -->
        <Style x:Key="GcSegBtnActive" TargetType="Button" BasedOn="{StaticResource GcSegBtnBase}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>

        <Style x:Key="GcSegBtnInactive" TargetType="Button" BasedOn="{StaticResource GcSegBtnBase}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7B8194"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="18" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 仅文字色变化，不动背景，避免与滑动 indicator 视觉冲突 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1F2937"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ╔═══════ Composer 输入框：扁平、贴合卡片 ═══════╗ -->
        <Style x:Key="GcComposerInput" TargetType="TextBox" BasedOn="{StaticResource UiTextBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="0,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ╔═══════ 发送圆形按钮（渐变） ═══════╗ -->
        <Style x:Key="GcSendBtn" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="{StaticResource GcAccentGrad}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="18"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.32" Color="#4F6EF7"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#3D5CE5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#3350D4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ╔═══════ 底部键位提示 chip ═══════╗ -->
        <Style x:Key="GcKeyChip" TargetType="Border">
            <Setter Property="Background" Value="#EEF1F8"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 底部 chip 后面跟随的说明文字（保持统一字号 / 颜色 / 间距） -->
        <Style x:Key="GcKeyHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="#9097A8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>

        <!-- ╔═══════ 翻译模式：紧凑下拉 ═══════╗ -->
        <Style x:Key="GcLangCombo" TargetType="ComboBox" BasedOn="{StaticResource UiComboBox}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6,32,6"/>
        </Style>

        <!-- 文件搜索 ListView 行 -->
        <Style x:Key="GcFileListItem" TargetType="ListViewItem">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter Columns="{TemplateBinding GridView.ColumnCollection}"
                                                  Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#F2F4FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E3EAFE"/>
                                <Setter Property="Foreground" Value="#1F2937"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="ChromeRoot"
            Background="{StaticResource GcGlassBg}"
            CornerRadius="18"
            BorderBrush="#E1E5EE"
            BorderThickness="1"
            Margin="14"
            Padding="0">
        <Border.Effect>
            <!-- 双层柔光：主阴影深、有蓝调，提升悬浮感 -->
            <DropShadowEffect BlurRadius="38" ShadowDepth="8" Opacity="0.22" Color="#1F2A4A"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="ResultRow" Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部高光描边（覆盖在所有 Row 之上 2px，跨整行） -->
            <Border Grid.Row="0" Grid.RowSpan="6"
                    VerticalAlignment="Top" Height="2" Margin="14,1,14,0"
                    CornerRadius="2" Background="{StaticResource GcInnerHighlight}"
                    IsHitTestVisible="False" Panel.ZIndex="10"/>

            <!-- ╔═══════ 标题栏 ═══════╗ -->
            <Grid Grid.Row="0" Margin="14,0,8,0"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown"
                  Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="18" Height="18" CornerRadius="5"
                            Background="{StaticResource GcAccentGrad}" VerticalAlignment="Center">
                        <TextBlock Text="✦" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="DanceMonkey" Margin="8,0,0,0"
                               FontSize="12.5" FontWeight="SemiBold"
                               Foreground="#1F2937" VerticalAlignment="Center"/>
                    <TextBlock Text=" · " Foreground="#B6BCCB" VerticalAlignment="Center" FontSize="12"/>
                    <TextBlock x:Name="ModeLabel" Text="AI 对话"
                               FontSize="12" Foreground="#6B7084" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="SaveNoteBtn" Content="存笔记"
                            Style="{StaticResource GcTitleSubtleBtn}"
                            Click="SaveNoteBtn_OnClick"
                            ToolTip="保存当前对话为 Markdown（Ctrl+S）"
                            Margin="0,0,2,0" Visibility="Collapsed"/>
                    <Button x:Name="ClearBtn" Content="清空"
                            Style="{StaticResource GcTitleSubtleBtn}"
                            Click="ClearBtn_OnClick"
                            Margin="0,0,8,0" Visibility="Collapsed"/>
                    <Button x:Name="ContinueMainAgentBtn" Content="主窗 Agent"
                            Style="{StaticResource GcTitleSubtleBtn}"
                            Click="ContinueMainAgentBtn_OnClick"
                            ToolTip="将对话上下文转到主窗口 AI 对话的 Agent 模式继续"
                            Margin="0,0,8,0" Visibility="Collapsed"/>
                    <Button x:Name="MaximizeBtn" Content="□"
                            Style="{StaticResource GcChromeBtn}"
                            Click="MaximizeBtn_OnClick"/>
                    <Button Content="✕"
                            Style="{StaticResource GcCloseBtn}"
                            Click="CloseBtn_OnClick"
                            ToolTip="关闭 (Esc)"/>
                </StackPanel>
            </Grid>

            <!-- ╔═══════ Segmented 模式切换（跑道形胶囊：圆角 = 高度的一半，无尖角） ═══════╗ -->
            <Border Grid.Row="1" Margin="14,4,14,10"
                    HorizontalAlignment="Stretch"
                    Height="42"
                    Background="#EEF1F8"
                    BorderBrush="Transparent" BorderThickness="0"
                    CornerRadius="21"
                    Padding="3"
                    SnapsToDevicePixels="True"
                    SizeChanged="SegmentBar_OnSizeChanged">
                <Grid ClipToBounds="True">
                    <!-- 浮动白胶囊：圆角与内区高度一致（36px → 18），端部为完整半圆 -->
                    <Border x:Name="SegmentIndicator"
                            HorizontalAlignment="Left" VerticalAlignment="Stretch"
                            Background="#FFFFFF" CornerRadius="18"
                            Width="0" Opacity="0"
                            Margin="0"
                            IsHitTestVisible="False"
                            RenderTransformOrigin="0,0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="SegmentIndicatorTranslate" X="0" Y="0"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.10" Color="#1F2A4A"/>
                        </Border.Effect>
                    </Border>

                    <Grid x:Name="SegmentBtnsHost" Panel.ZIndex="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ModeAiBtn"
                                Grid.Column="0"
                                Style="{StaticResource GcSegBtnActive}"
                                Click="ModeAiBtn_OnClick"
                                HorizontalAlignment="Stretch"
                                Margin="0"
                                ToolTip="与助手对话（默认） · Tab 切换">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="✦ " FontSize="12.5"/>
                                <TextBlock Text="AI 对话"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ModeTranslateBtn"
                                Grid.Column="1"
                                Style="{StaticResource GcSegBtnInactive}"
                                Click="ModeTranslateBtn_OnClick"
                                HorizontalAlignment="Stretch"
                                Margin="0"
                                ToolTip="文本翻译 · Tab 切换">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🌐 " FontSize="12.5"/>
                                <TextBlock Text="翻译"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ModeFileBtn"
                                Grid.Column="2"
                                Style="{StaticResource GcSegBtnInactive}"
                                Click="ModeFileBtn_OnClick"
                                HorizontalAlignment="Stretch"
                                Margin="0"
                                ToolTip="按文件名搜索 · Tab 切换">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🔍 " FontSize="12.5"/>
                                <TextBlock Text="文件"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- ╔═══════ 模式专属选项 ═══════╗ -->
            <!-- 翻译：语言 -->
            <Grid x:Name="TranslateLangPanel" Grid.Row="2" Margin="14,0,14,8" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SourceLangCombo" Grid.Column="0" Style="{StaticResource GcLangCombo}">
                    <ComboBoxItem Content="自动" Tag="auto" IsSelected="True"/>
                    <ComboBoxItem Content="中文" Tag="zh"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="日本語" Tag="ja"/>
                    <ComboBoxItem Content="Deutsch" Tag="de"/>
                    <ComboBoxItem Content="Français" Tag="fr"/>
                    <ComboBoxItem Content="Español" Tag="es"/>
                    <ComboBoxItem Content="한국어" Tag="ko"/>
                </ComboBox>
                <Button Grid.Column="1" Content="⇄" VerticalAlignment="Center" Margin="8,0,8,0" Padding="11,6"
                        Style="{StaticResource UiBtnSecondary}" FontSize="12" Click="SwapLang_OnClick"
                        ToolTip="交换源与目标语言"/>
                <ComboBox x:Name="TargetLangCombo" Grid.Column="2" Style="{StaticResource GcLangCombo}">
                    <ComboBoxItem Content="中文" Tag="zh" IsSelected="True"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="日本語" Tag="ja"/>
                    <ComboBoxItem Content="Deutsch" Tag="de"/>
                    <ComboBoxItem Content="Français" Tag="fr"/>
                    <ComboBoxItem Content="Español" Tag="es"/>
                    <ComboBoxItem Content="한국어" Tag="ko"/>
                </ComboBox>
            </Grid>

            <!-- AI 对话：Agent 模式 -->
            <StackPanel x:Name="AiAgentPanel" Grid.Row="2" Orientation="Horizontal"
                        Margin="14,0,14,8" Visibility="Collapsed">
                <Button x:Name="GcAgentModeBtn"
                        Style="{StaticResource GcTitleSubtleBtn}"
                        Click="GcAgentModeBtn_OnClick"
                        ToolTip="Agent Core：读写沙箱/笔记、Shell（需审批）"
                        Padding="10,4" Margin="0,0,8,0">
                    <TextBlock x:Name="GcAgentModeBtnText" Text="Agent: Off"/>
                </Button>
                <ComboBox x:Name="GcAgentPermCombo"
                          Style="{StaticResource GcLangCombo}"
                          Width="120" Visibility="Collapsed"
                          SelectionChanged="GcAgentPermCombo_OnSelectionChanged"
                          ToolTip="Agent 权限：Plan 只读 / Ask 逐次审批 / Auto 自动执行">
                    <ComboBoxItem Content="Plan" Tag="Plan"/>
                    <ComboBoxItem Content="Ask" Tag="Ask" IsSelected="True"/>
                    <ComboBoxItem Content="Auto" Tag="Auto"/>
                </ComboBox>
            </StackPanel>

            <!-- 文件：目录 -->
            <Grid x:Name="FileSearchPanel" Grid.Row="2" Margin="14,0,14,8" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FileSearchFolderBox" Grid.Column="0"
                         Style="{StaticResource UiTextBox}"
                         FontSize="12" IsReadOnly="True" Padding="10,7"
                         VerticalContentAlignment="Center"
                         ToolTip="搜索范围"/>
                <Button Grid.Column="1" Content="📂 文件夹" Margin="8,0,0,0" Padding="12,7" FontSize="12"
                        Style="{StaticResource UiBtnSecondary}" Click="FileSearchPickFolder_OnClick"/>
            </Grid>

            <!-- ╔═══════ Composer 一体化卡片 ═══════╗ -->
            <Border Grid.Row="3" Margin="14,0,14,10"
                    Background="#FFFFFF"
                    BorderBrush="#E1E5EE" BorderThickness="1"
                    CornerRadius="14" Padding="14,10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.06" Color="#1F2A4A"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="ComposerLeadIcon" Grid.Column="0"
                               Text="✦" FontSize="16"
                               Foreground="#5C7DFF"
                               VerticalAlignment="Center" Margin="2,0,12,0"/>

                    <Grid Grid.Column="1">
                        <TextBox x:Name="InputBox"
                                 Style="{StaticResource GcComposerInput}"
                                 MinHeight="28"
                                 MaxHeight="56"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 KeyDown="InputBox_OnKeyDown"
                                 TextChanged="InputBox_OnTextChanged"/>
                        <TextBlock x:Name="InputPlaceholder"
                                   Text="问任何问题，Enter 发送…"
                                   Foreground="#9CA0B0"
                                   FontSize="15"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0"/>
                    </Grid>

                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Button x:Name="PrimaryActionBtn"
                                Style="{StaticResource GcSendBtn}"
                                Click="PrimaryActionBtn_OnClick"
                                ToolTip="发送 (Enter)">
                            <TextBlock x:Name="PrimaryActionIcon" Text="↑" FontSize="16" Margin="0,-2,0,0"/>
                        </Button>
                        <!-- 等待 AI 回复时的加载指示器（替代 Send 按钮） -->
                        <StackPanel x:Name="LoadingIndicator" Orientation="Horizontal"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                            <StackPanel.Resources>
                                <Storyboard x:Key="DotPulse" RepeatBehavior="Forever">
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.3"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.5" Value="0.3"/>
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.3"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.35" Value="1"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.65" Value="0.3"/>
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.3"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.5" Value="1"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.8" Value="0.3"/>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </StackPanel.Resources>
                            <Ellipse x:Name="Dot1" Width="6" Height="6" Fill="{StaticResource BrushAccent}" Margin="3,0" Opacity="0.3"/>
                            <Ellipse x:Name="Dot2" Width="6" Height="6" Fill="{StaticResource BrushAccent}" Margin="3,0" Opacity="0.3"/>
                            <Ellipse x:Name="Dot3" Width="6" Height="6" Fill="{StaticResource BrushAccent}" Margin="3,0" Opacity="0.3"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ╔═══════ 内容区 ═══════╗ -->
            <Grid x:Name="ResultHost" Grid.Row="4" Margin="14,0,14,10" Visibility="Collapsed" MinHeight="220">
                <Border Background="#FFFFFF"
                        BorderBrush="#E1E5EE" BorderThickness="1"
                        CornerRadius="14" Padding="0"
                        ClipToBounds="True">
                    <Grid>
                        <wv2:WebView2 x:Name="ChatWeb" Margin="0" Visibility="Visible"/>
                        <Grid x:Name="TranslateResultPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="14,10,12,4" LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="译文" FontSize="11"
                                           FontWeight="SemiBold" Foreground="#9097A8"
                                           VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="📋 复制"
                                        Style="{StaticResource GcTitleSubtleBtn}"
                                        Click="CopyTranslateResult_OnClick"/>
                            </DockPanel>
                            <TextBox x:Name="TranslateResultText" Grid.Row="1" Style="{StaticResource UiResultBox}"
                                     Margin="14,0,14,12" MinHeight="120" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" IsReadOnly="True"
                                     BorderBrush="Transparent" Background="#FAFBFE"/>
                        </Grid>
                        <Grid x:Name="FileResultPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="14,10,14,4" LastChildFill="False">
                                <CheckBox x:Name="FileSearchSubfoldersCheck" DockPanel.Dock="Left" Content="含子文件夹"
                                          FontSize="11" Foreground="#5B6478"
                                          VerticalAlignment="Center" IsChecked="True"/>
                                <TextBlock x:Name="FileSearchStatusText" DockPanel.Dock="Right" FontSize="11"
                                           Foreground="#9097A8" VerticalAlignment="Center"/>
                            </DockPanel>
                            <ListView x:Name="FileSearchList" Grid.Row="1" Margin="8,0,8,8"
                                      BorderThickness="0" Background="Transparent" FontSize="12"
                                      ItemContainerStyle="{StaticResource GcFileListItem}"
                                      MouseDoubleClick="FileSearchList_OnMouseDoubleClick"
                                      PreviewMouseRightButtonDown="FileSearchList_OnPreviewMouseRightButtonDown">
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="打开文件" Click="OpenFileMenu_OnClick"/>
                                        <MenuItem Header="打开源文件夹" Click="OpenFileFolderMenu_OnClick"/>
                                        <Separator/>
                                        <MenuItem Header="复制完整路径" Click="CopyFilePathMenu_OnClick"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="名称" Width="180" DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="源文件夹" Width="240" DisplayMemberBinding="{Binding FolderDisplay}"/>
                                        <GridViewColumn Header="创建" Width="95" DisplayMemberBinding="{Binding CreatedDisplay}"/>
                                        <GridViewColumn Header="修改" Width="95" DisplayMemberBinding="{Binding ModifiedDisplay}"/>
                                        <GridViewColumn Header="大小" Width="72" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBlock x:Name="FileSearchEmptyText"
                                       Grid.Row="1"
                                       Margin="20,12,20,12"
                                       Foreground="#9097A8"
                                       FontSize="12.5"
                                       Text="未找到匹配文件。可尝试更短关键字，或勾选「含子文件夹」。"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ╔═══════ 底部键位提示栏 ═══════╗ -->
            <Grid Grid.Row="5" Margin="18,4,18,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource GcKeyChip}">
                        <TextBlock Text="Enter" FontSize="11" FontWeight="Medium" Foreground="#5B6478"/>
                    </Border>
                    <TextBlock x:Name="HintPrimary" Text="发送" Style="{StaticResource GcKeyHint}"/>

                    <Border Style="{StaticResource GcKeyChip}">
                        <TextBlock Text="Tab" FontSize="11" FontWeight="Medium" Foreground="#5B6478"/>
                    </Border>
                    <TextBlock Text="切换模式" Style="{StaticResource GcKeyHint}"/>

                    <Border Style="{StaticResource GcKeyChip}">
                        <TextBlock Text="Ctrl + S" FontSize="11" FontWeight="Medium" Foreground="#5B6478"/>
                    </Border>
                    <TextBlock Text="存笔记" Style="{StaticResource GcKeyHint}"/>

                    <Border Style="{StaticResource GcKeyChip}">
                        <TextBlock Text="Esc" FontSize="11" FontWeight="Medium" Foreground="#5B6478"/>
                    </Border>
                    <TextBlock Text="关闭" FontSize="11.5" Foreground="#9097A8" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="ContextHint" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="11.5" Foreground="#9097A8" Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Border>
</Window>
