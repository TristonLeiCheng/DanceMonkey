<Window x:Class="DesktopAssistant.HealthReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="RootBorder" CornerRadius="18"
            Background="{StaticResource BrushSurface}"
            BorderBrush="{StaticResource BrushBorderSubtle}"
            BorderThickness="1"
            Margin="16" Padding="0"
            MinWidth="380" MaxWidth="440">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.18" Color="#000000"/>
        </Border.Effect>

        <StackPanel>
            <!-- 关闭按钮 -->
            <Button x:Name="CloseBtn" Content="✕" HorizontalAlignment="Right"
                    Margin="0,8,12,0" Padding="6,2"
                    FontSize="14" Foreground="{StaticResource BrushTextMuted}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    Click="Close_OnClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <StackPanel Margin="32,0,32,28">
                <!-- 图标 -->
                <TextBlock x:Name="IconText" Text="💧" FontSize="52"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <!-- 标题 -->
                <TextBlock x:Name="TitleText" Text="{DynamicResource Health.WaterTitle}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>

                <!-- 描述 -->
                <TextBlock x:Name="DescText" Text="{DynamicResource Health.WaterDesc}"
                           FontSize="13.5" Foreground="{StaticResource BrushTextSecondary}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           LineHeight="22" Margin="0,0,0,20"/>

                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="DoneBtn" Style="{StaticResource UiBtnPrimary}"
                            Padding="24,10" MinWidth="140" FontSize="14"
                            Click="Done_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="DoneBtnIcon" Text="✅" Margin="0,0,6,0"/>
                            <TextBlock x:Name="DoneBtnText" Text="{DynamicResource Health.WaterDone}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="LaterBtn" Content="{DynamicResource Health.Later}"
                            Style="{StaticResource UiBtnSecondary}"
                            Padding="20,10" MinWidth="100" FontSize="14"
                            Margin="10,0,0,0"
                            Click="Later_OnClick"/>
                </StackPanel>

                <!-- 统计 -->
                <TextBlock x:Name="StatsText"
                           FontSize="12" Foreground="{StaticResource BrushTextMuted}"
                           HorizontalAlignment="Center" Margin="0,14,0,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
