<Window x:Class="DesktopAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nav="clr-namespace:DesktopAssistant"
        xmlns:swc="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Icon="{StaticResource AppWindowIcon}"
        Title="DanceMonkey"
        Height="660" Width="960" MinWidth="740" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource BrushPageBg}"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <swc:BooleanToVisibilityConverter x:Key="NavBoolToVis"/>
        <!-- Caption bar buttons — minimal -->
        <Style x:Key="CaptionBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9A9286"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A000000"/>
                                <Setter Property="Foreground" Value="#2D2A26"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Navigation：选中态用 Style.DataTrigger 绑定附加属性（模板内 Property=(nav:...) 无法编译）；左侧条单独一列避免被背景盖住 -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrushSidebarText}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Effect" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="14,0,14,0"/>
            <Setter Property="Margin" Value="4,2,8,2"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="AccentBar"
                                    Grid.Column="0"
                                    Width="0"
                                    CornerRadius="2"
                                    Margin="0"
                                    VerticalAlignment="Stretch"
                                    Background="Transparent"
                                    Visibility="Collapsed"/>
                            <Border x:Name="bd"
                                    Grid.Column="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="0"
                                    Effect="{TemplateBinding Effect}">
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=(nav:NavButtonHelper.IsNavActive), RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushSidebarNavActiveBg}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BrushSidebarNavActiveBorder}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Effect" Value="{x:Null}"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushSidebarTextActive}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                        <Condition Binding="{Binding Path=(nav:NavButtonHelper.IsNavActive), RelativeSource={RelativeSource Self}}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource BrushSidebarHover}"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                        <Condition Binding="{Binding Path=(nav:NavButtonHelper.IsNavActive), RelativeSource={RelativeSource Self}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource BrushSidebarNavActiveHover}"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 侧栏分组：可展开/收起 -->
        <Style x:Key="SidebarExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="Transparent">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderToggle"
                                              DockPanel.Dock="Top"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Padding="10,8,12,8"
                                              HorizontalContentAlignment="Stretch"
                                              Focusable="False"
                                              IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ExpArrow" Grid.Column="0" Text="▾" FontSize="10"
                                                   Foreground="{StaticResource BrushSidebarExpanderChevron}"
                                                   VerticalAlignment="Center" Margin="10,0,6,0"/>
                                        <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"/>
                                    </Grid>
                                </ToggleButton>
                                <Border x:Name="ExpandSite" Background="Transparent" Visibility="Visible">
                                    <ContentPresenter ContentSource="Content"/>
                                </Border>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="collapsed">
                                <Setter TargetName="HeaderToggle" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="ExpArrow" Property="Text" Value="▸"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ExpArrow" Property="Text" Value="▾"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="228"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════ SIDEBAR ═══════════════ -->
        <Border Grid.Column="0"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,1,0"
                SnapsToDevicePixels="True">
            <Grid>
                <!-- 底色：暖米黄渐变 -->
                <Rectangle Fill="{StaticResource BrushSidebarRailBg}"/>
                <!-- 方格纹理：极淡 -->
                <Rectangle Fill="{StaticResource BrushSidebarGridOverlay}" IsHitTestVisible="False"/>
                <DockPanel LastChildFill="True">
                <!-- Brand header -->
                <StackPanel x:Name="BrandHeaderPanel" DockPanel.Dock="Top" Margin="14,14,14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="BrandLogo" Width="38" Height="38" CornerRadius="11" Margin="0,0,12,0"
                                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="#FFFFFF"
                                ClipToBounds="True" SnapsToDevicePixels="True">
                            <Image Source="{StaticResource LogoImageSource}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel x:Name="BrandTextPanel" VerticalAlignment="Center">
                            <TextBlock Text="DanceMonkey" FontSize="14.5" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>
                            <TextBlock Text="桌面助手" FontSize="10" Foreground="{StaticResource BrushSidebarMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Border x:Name="BrandSeparator" Height="1" Margin="0,16,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#14000000" Offset="0.5"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <!-- Collapse toggle + Version footer -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12">
                    <Border Height="1" Margin="10,0,10,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#12000000" Offset="0.5"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Button x:Name="BtnSidebarToggle" Click="BtnSidebarToggle_OnClick"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Height="32"
                            HorizontalAlignment="Stretch" Margin="8,0,8,4"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="tb" Background="Transparent" CornerRadius="10" Padding="0" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="ToggleIcon" Text="◀" FontSize="11" Foreground="{StaticResource BrushSidebarMuted}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="ToggleLabel" Text="  收起" FontSize="11" Foreground="{StaticResource BrushSidebarMuted}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="tb" Property="Background" Value="{StaticResource BrushSidebarHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="VersionLabel" Text="v1.2 · .NET 8" Foreground="{StaticResource BrushSidebarMuted}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0" Padding="0,0,4,0">
                    <StackPanel>
                        <Expander x:Name="NavWorkbenchExpander" Style="{StaticResource SidebarExpanderStyle}" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="工 作 台" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSidebarMuted}"/>
                            </Expander.Header>
                            <StackPanel>
                                <Button x:Name="NavAiChat" Tag="AiChat" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💬" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.AiChat}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavNotes" Tag="Notes" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📝" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.Notes}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavPpt" Tag="Ppt" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick" ToolTip="{DynamicResource Nav.PptTip}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.Ppt}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavTodo" Tag="Todo" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="☑" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.Todo}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavQuickAccess" Tag="QuickAccess" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.QuickAccess}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavHomepage" Tag="PersonalHomepage" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🏠" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.Homepage}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Expander>

                        <Expander x:Name="NavFuncExpander" Style="{StaticResource SidebarExpanderStyle}" IsExpanded="True" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="沟 通 协 作" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSidebarMuted}"/>
                            </Expander.Header>
                            <StackPanel>
                                <Button x:Name="NavMeeting" Tag="MeetingAssistant" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎤" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.Meeting}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Expander>

                        <Expander x:Name="NavToolsExpander" Style="{StaticResource SidebarExpanderStyle}" IsExpanded="False" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="文 件 效 率" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSidebarMuted}"/>
                            </Expander.Header>
                            <StackPanel Margin="0,0,0,0">
                                <Button x:Name="NavFileManager" Tag="FileManager" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📂" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.FileManager}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavFileTools" Tag="FileTools" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📁" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.FileTools}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavPdfTools" Tag="PdfTools" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📄" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.PdfTools}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Expander>

                        <Expander x:Name="NavSystemExpander" Style="{StaticResource SidebarExpanderStyle}" IsExpanded="False" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="系 统 维 护" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSidebarMuted}"/>
                            </Expander.Header>
                            <StackPanel>
                                <Button x:Name="NavCleanup" Tag="Cleanup" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧹" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.Cleanup}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavCodexProxy" Tag="CodexProxy" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔁" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.CodexProxy}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavNetwork" Tag="NetworkMonitor" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📡" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.Network}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavPasswordVault" Tag="PasswordVault" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔐" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.PasswordVault}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="NavProcessDiag" Tag="ProcessDiagnostics" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔬" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="进程诊断" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Expander>

                        <Expander x:Name="NavOtherExpander" Style="{StaticResource SidebarExpanderStyle}" IsExpanded="False" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="其 他" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushSidebarMuted}"/>
                            </Expander.Header>
                            <StackPanel>
                                <Button x:Name="NavDance" Tag="Dance" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💃" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Nav.Dance}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Expander>

                        <Border Height="1" Margin="18,12,18,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#10000000" Offset="0.5"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <Button x:Name="NavSettings" Tag="Settings" Style="{StaticResource NavButtonStyle}" Click="NavButton_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="14" Width="24" TextAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource Nav.Settings}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ CONTENT AREA ═══════════════ -->
        <Grid Grid.Column="1">
            <!-- 主内容区底层：暖米黄 + 极淡方格 -->
            <Rectangle Fill="{StaticResource BrushPageBg}"/>
            <Rectangle Fill="{StaticResource BrushPageGridOverlay}" IsHitTestVisible="False"/>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar — blends with content bg -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0" IsHitTestVisible="False">
                    <TextBlock x:Name="PageTitleBar"
                               Text="翻译工作台"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource BrushTextSecondary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionBarButton}" Content="&#x2014;" ToolTip="{DynamicResource TitleBar.Minimize}" Click="CaptionMinimize_OnClick"
                            Foreground="{StaticResource BrushTextMuted}"/>
                    <Button x:Name="BtnCaptionMaximize" Style="{StaticResource CaptionBarButton}"
                            FontFamily="Segoe MDL2 Assets" FontSize="10"
                            ToolTip="{DynamicResource TitleBar.Maximize}" Click="CaptionMaximize_OnClick"
                            Foreground="{StaticResource BrushTextMuted}"/>
                    <Button Style="{StaticResource CaptionCloseButton}" Content="&#x2715;" ToolTip="{DynamicResource TitleBar.Close}" Click="CaptionClose_OnClick"
                            Foreground="{StaticResource BrushTextMuted}"/>
                </StackPanel>
            </Grid>

            <!-- Page content -->
            <Border Grid.Row="1" Background="Transparent" Padding="0">
                <Grid Margin="24,0,24,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 笔记页工具栏 + 设置 -->
                    <StackPanel Grid.Row="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Orientation="Horizontal"
                                Margin="0,0,0,8"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel x:Name="NotesToolbarPanel"
                                    Visibility="Collapsed"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="{DynamicResource Notes.Today}" Style="{StaticResource UiBtnPrimary}" Padding="7,5" Margin="0,0,4,0" FontSize="11.5"
                                    Click="NotesToolbar_Today_OnClick"/>
                            <Button Content="{DynamicResource Notes.New}" Style="{StaticResource UiBtnSecondary}" Padding="7,5" Margin="0,0,4,0" FontSize="11.5"
                                    ToolTip="{DynamicResource Notes.NewNote}" Click="NotesToolbar_NewNote_OnClick"/>
                            <Button Content="{DynamicResource Notes.Folder}" Style="{StaticResource UiBtnSecondary}" Padding="7,5" Margin="0,0,4,0" FontSize="11.5"
                                    ToolTip="{DynamicResource Notes.NewFolder}" Click="NotesToolbar_NewFolder_OnClick"/>
                            <Button Content="{DynamicResource Notes.Sticky}" Style="{StaticResource UiBtnAccentBlue}" Padding="7,5" Margin="0,0,4,0" FontSize="11.5"
                                    Click="NotesToolbar_Sticky_OnClick"/>
                            <Button Content="{DynamicResource Notes.Capture}" Style="{StaticResource UiBtnAccentBlue}" Padding="7,5" Margin="0,0,8,0" FontSize="11.5"
                                    ToolTip="{DynamicResource Notes.QuickCapture}" Click="NotesToolbar_QuickCapture_OnClick"/>
                            <Border Width="1" Height="20" Margin="0,0,8,0" Background="{StaticResource BrushBorderSubtle}" VerticalAlignment="Center"/>
                            <Button x:Name="NotesToolbarMoreBtn" Content="{DynamicResource Notes.More}" Style="{StaticResource UiBtnSecondary}" Padding="7,5" FontSize="11.5"
                                    ToolTip="{DynamicResource Notes.More}" Click="NotesToolbar_More_OnClick">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{DynamicResource Notes.RefreshList}" Click="NotesToolbar_Refresh_OnClick"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource Notes.ExportZip}" Click="NotesToolbar_ExportZip_OnClick"/>
                                        <MenuItem Header="{DynamicResource Notes.ImportZip}" Click="NotesToolbar_ImportZip_OnClick"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource Notes.OpenFolder}" Click="NotesToolbar_OpenFolder_OnClick"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Content host — flat, no outer card border -->
                    <Border Grid.Row="1"
                            Background="Transparent"
                            CornerRadius="12"
                            ClipToBounds="True">
                        <ContentControl x:Name="PageHost" Margin="0" Padding="0"/>
                    </Border>
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
