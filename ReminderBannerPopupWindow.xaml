<Window x:Class="DesktopAssistant.ReminderBannerPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="Manual"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" Opacity="0">
    <Window.Resources>
        <LinearGradientBrush x:Key="GlassBg" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#F0F4FAFE" Offset="0"/>
            <GradientStop Color="#E6ECF4FA" Offset="0.5"/>
            <GradientStop Color="#F0F4FAFE" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassTint" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#98FFFFFF" Offset="0"/>
            <GradientStop Color="#82EEF2FA" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Border x:Name="RootCard" Margin="12,6" MinWidth="520" MaxWidth="640" CornerRadius="18"
            Background="{StaticResource GlassBg}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="36" ShadowDepth="6" Opacity="0.26" Color="#1A2540"/>
        </Border.Effect>
        <Grid>
            <Border x:Name="FrostLayer" CornerRadius="18"/>
            <Border CornerRadius="18" Background="{StaticResource GlassTint}"/>
            <Border CornerRadius="18" BorderBrush="#75FFFFFF" BorderThickness="1" IsHitTestVisible="False"/>

            <Grid Margin="18,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="IconText" Grid.Column="0" Text="🔔" FontSize="32"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock x:Name="TitleText" Text="提醒" FontSize="16" FontWeight="SemiBold"
                               Foreground="#1B2433"/>
                    <TextBlock x:Name="DescText" Text="" FontSize="13" Foreground="#525C6E"
                               TextWrapping="Wrap" MaxHeight="36" TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0"/>
                    <TextBlock x:Name="StatsText" FontSize="11" Foreground="#8A93A6" Margin="0,3,0,0"/>
                </StackPanel>

                <Button x:Name="DoneBtn" Grid.Column="2" Style="{StaticResource UiBtnPrimary}"
                        Padding="18,9" MinWidth="100" FontSize="13"
                        VerticalAlignment="Center" Click="Done_OnClick">
                    <TextBlock x:Name="DoneBtnText" Text="完成"/>
                </Button>
                <Button x:Name="LaterBtn" Grid.Column="3" Content="稍后"
                        Style="{StaticResource UiBtnSecondary}"
                        Padding="14,9" MinWidth="80" FontSize="13" Margin="8,0,0,0"
                        VerticalAlignment="Center" Click="Later_OnClick"/>

                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-6,-4,0" Padding="4,1" FontSize="11" Foreground="#9097A8"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="Close_OnClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
