<Window x:Class="DesktopAssistant.ReminderCompactPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="Manual"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" Opacity="0">
    <Window.Resources>
        <SolidColorBrush x:Key="PillBg" Color="#F0181C24"/>
        <LinearGradientBrush x:Key="PillTint" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D0181C24" Offset="0"/>
            <GradientStop Color="#E8121418" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <!-- 外层只负责阴影，内层 Clip 保证胶囊边缘干净 -->
    <Grid Margin="16">
        <Border x:Name="ShadowHost" CornerRadius="25" Background="Transparent">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="3" Opacity="0.32" Color="#000000"/>
            </Border.Effect>

            <Border x:Name="RootCard" MinHeight="50" CornerRadius="25"
                    Background="{StaticResource PillBg}" ClipToBounds="True"
                    Padding="6,0">
                <Grid>
                    <Border x:Name="FrostLayer" CornerRadius="25"/>
                    <Border x:Name="TintLayer" CornerRadius="25" Background="{StaticResource PillTint}"/>
                    <Border x:Name="StrokeLayer" CornerRadius="25"
                            BorderBrush="#35FFFFFF" BorderThickness="1" IsHitTestVisible="False"/>

                    <!-- 收起：单行胶囊 -->
                    <Grid x:Name="CompactRow" Height="50">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="IconText" Grid.Column="0" Text="🔔" FontSize="20"
                                   VerticalAlignment="Center" Margin="16,0,10,0"/>

                        <TextBlock x:Name="TitleText" Grid.Column="1" Text="提醒"
                                   FontSize="13.5" FontWeight="SemiBold" Foreground="#F0F0F5"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   MaxWidth="220"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="8,0,10,0">
                            <Button x:Name="DoneBtn" Content="✓" Padding="0" Width="36" Height="36"
                                    FontSize="15" FontWeight="Bold" Foreground="White"
                                    Background="#FF5C7DFF" BorderThickness="0" Cursor="Hand"
                                    Click="Done_OnClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                                CornerRadius="18" Width="36" Height="36">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="LaterBtn" Content="⏱" Padding="0" Width="36" Height="36"
                                    FontSize="13" Foreground="#D0D4DE" Background="#28FFFFFF"
                                    BorderThickness="0" Cursor="Hand" Margin="6,0,0,0"
                                    ToolTip="稍后提醒" Click="Later_OnClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                                CornerRadius="18" Width="36" Height="36">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#40FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- 展开：圆角卡片（非胶囊） -->
                    <StackPanel x:Name="ExpandedPanel" Visibility="Collapsed" Margin="18,16">
                        <TextBlock x:Name="ExpandedDesc" Text="" FontSize="12.5" Foreground="#C8CCD4"
                                   TextWrapping="Wrap" MaxWidth="300" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="ExpandedDoneBtn" Style="{StaticResource UiBtnPrimary}"
                                    Padding="14,7" FontSize="12" Click="Done_OnClick">
                                <TextBlock x:Name="ExpandedDoneText" Text="完成"/>
                            </Button>
                            <Button x:Name="ExpandedLaterBtn" Content="稍后" Style="{StaticResource UiBtnSecondary}"
                                    Padding="12,7" FontSize="12" Margin="8,0,0,0" Click="Later_OnClick"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
