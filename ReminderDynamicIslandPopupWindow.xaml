<Window x:Class="DesktopAssistant.ReminderDynamicIslandPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="Manual"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" Opacity="0">
    <Window.Resources>
        <SolidColorBrush x:Key="IslandBlack" Color="#FF000000"/>
        <LinearGradientBrush x:Key="CameraLens" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0A0A0E" Offset="0"/>
            <GradientStop Color="#FF050508" Offset="0.55"/>
            <GradientStop Color="#FF151820" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CameraRing" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF1E1E24" Offset="0"/>
            <GradientStop Color="#FF0C0C10" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <!-- 顶部居中，贴近屏幕边缘 -->
    <Grid Margin="0,2,0,0" HorizontalAlignment="Center">
        <Border x:Name="ShadowHost" Background="Transparent">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="2" Opacity="0.45" Color="#000000"/>
            </Border.Effect>

            <Border x:Name="IslandShell" Width="420" Height="44"
                    Background="{StaticResource IslandBlack}" ClipToBounds="True"
                    Cursor="Hand" MouseLeftButtonUp="IslandShell_OnTap">
                <Grid>
                    <Border x:Name="FrostLayer" Opacity="0.15"/>
                    <Border x:Name="TintLayer" Background="#CC000000" IsHitTestVisible="False"/>

                    <!-- ═══ 收起态：长条胶囊，摄像头居中 ═══ -->
                    <Grid x:Name="CompactRow" Height="44">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：图标 + 标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                Margin="0,0,4,0">
                        <Border Width="26" Height="26" CornerRadius="7"
                                Background="#28FFFFFF" Margin="0,0,8,0">
                            <TextBlock x:Name="IconText" Text="🔔" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TitleText" Text="提醒"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#F2F2F7"
                                   VerticalAlignment="Center" MaxWidth="130"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- 中央：模拟前置摄像头 -->
                    <Grid Grid.Column="1" Width="52" Height="44"
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          IsHitTestVisible="False">
                        <Ellipse Width="14" Height="14" Fill="{StaticResource CameraRing}"/>
                        <Ellipse Width="10" Height="10" Fill="{StaticResource CameraLens}"/>
                        <Ellipse Width="3.5" Height="3.5" Fill="#55384858"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Margin="-3,-3,0,0"/>
                    </Grid>

                    <!-- 右侧：状态指示 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Left"
                                Margin="4,0,16,0">
                        <Ellipse x:Name="PulseDot" Width="7" Height="7" Fill="#FF34C759"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="CompactHintText" Text="点击展开"
                                   FontSize="12" Foreground="#99FFFFFF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- ═══ 展开态：完整交互面板 ═══ -->
                <Grid x:Name="ExpandedPanel" Visibility="Collapsed" Opacity="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 顶部摄像头（展开后仍保留） -->
                    <Grid Grid.Row="0" Height="28" Margin="0,6,0,0" IsHitTestVisible="False">
                        <Ellipse Width="12" Height="12" Fill="{StaticResource CameraRing}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource CameraLens}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 标题区 -->
                    <Grid Grid.Row="1" Margin="22,4,22,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="52" Height="52" CornerRadius="12"
                                Background="#22FFFFFF" Margin="0,0,14,0">
                            <TextBlock x:Name="ExpandedIconText" Text="🔔" FontSize="28"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ExpandedTitleText" Text="提醒"
                                       FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="ExpandedSubtitleText" Text=""
                                       FontSize="12.5" Foreground="#99FFFFFF" Margin="0,3,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="✕" VerticalAlignment="Top"
                                Padding="6,3" FontSize="11" Foreground="#80FFFFFF"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="Close_OnClick">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="Transparent" CornerRadius="999"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#25FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- 描述 -->
                    <TextBlock x:Name="DescText" Grid.Row="2" Text=""
                               FontSize="13" Foreground="#C8CCD4" TextWrapping="Wrap"
                               LineHeight="20" Margin="22,14,22,0" MaxWidth="376"/>

                    <!-- 操作按钮 -->
                    <StackPanel Grid.Row="3" Margin="22,18,22,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="DoneBtn" Padding="28,11" MinWidth="140" FontSize="14"
                                    Background="#FFFFFFFF" Foreground="#FF111111"
                                    BorderThickness="0" Cursor="Hand" Click="Done_OnClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                                CornerRadius="22" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Opacity" Value="0.88"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock x:Name="DoneBtnText" Text="完成" FontWeight="SemiBold"/>
                            </Button>
                            <Button x:Name="LaterBtn" Content="稍后" Padding="22,11" MinWidth="100"
                                    FontSize="14" Margin="12,0,0,0" Cursor="Hand" Click="Later_OnClick">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="#28FFFFFF" CornerRadius="22"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#40FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Foreground>
                                    <SolidColorBrush Color="#F0F0F5"/>
                                </Button.Foreground>
                            </Button>
                        </StackPanel>
                        <TextBlock x:Name="StatsText" FontSize="11" Foreground="#66FFFFFF"
                                   HorizontalAlignment="Center" Margin="0,14,0,0"/>
                    </StackPanel>
                </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
