<Window x:Class="DesktopAssistant.ReminderPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Opacity="0">
    <Window.Resources>
        <LinearGradientBrush x:Key="GlassBg" StartPoint="0,0" EndPoint="0.4,1">
            <GradientStop Color="#F4F7FBFE" Offset="0"/>
            <GradientStop Color="#ECEFF6FC" Offset="0.55"/>
            <GradientStop Color="#E3E9F2FA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassTint" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#A8FFFFFF" Offset="0"/>
            <GradientStop Color="#92F5F8FD" Offset="0.5"/>
            <GradientStop Color="#86EFF3FB" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassHighlight" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B0FFFFFF" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="IconChipBg" Color="#225C7DFF"/>
    </Window.Resources>

    <Border x:Name="GlassCard" CornerRadius="22"
            Margin="20" Padding="0"
            MinWidth="400" MaxWidth="460"
            Background="{StaticResource GlassBg}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="44" ShadowDepth="9" Opacity="0.30" Color="#16203A"/>
        </Border.Effect>

        <Grid>
            <Border x:Name="FrostLayer" CornerRadius="22"/>
            <Border CornerRadius="22" Background="{StaticResource GlassTint}"/>
            <Border VerticalAlignment="Top" Height="72" Margin="1.2,1.2,1.2,0"
                    CornerRadius="22,22,0,0"
                    Background="{StaticResource GlassHighlight}"
                    IsHitTestVisible="False"/>
            <Border CornerRadius="22" BorderBrush="#7AFFFFFF" BorderThickness="1.2"
                    IsHitTestVisible="False"/>

            <StackPanel>
                <Button x:Name="CloseBtn" Content="✕" HorizontalAlignment="Right"
                        Margin="0,12,16,0" Padding="7,3"
                        FontSize="13" Foreground="#8A93A6"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="Close_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="Transparent" CornerRadius="999" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#1A000000"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Margin="38,2,38,30">
                    <Border Width="84" Height="84" CornerRadius="42"
                            HorizontalAlignment="Center" Margin="0,4,0,16"
                            Background="{StaticResource IconChipBg}"
                            BorderBrush="#5EFFFFFF" BorderThickness="1">
                        <TextBlock x:Name="IconText" Text="🔔" FontSize="42"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="TitleText" Text="提醒"
                               FontSize="21" FontWeight="SemiBold"
                               Foreground="#1B2433"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>

                    <TextBlock x:Name="DescText" Text=""
                               FontSize="13.5" Foreground="#525C6E"
                               TextWrapping="Wrap" TextAlignment="Center"
                               LineHeight="22" Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="DoneBtn" Style="{StaticResource UiBtnPrimary}"
                                Padding="24,10" MinWidth="140" FontSize="14"
                                Click="Done_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="DoneBtnIcon" Text="✅" Margin="0,0,6,0"/>
                                <TextBlock x:Name="DoneBtnText" Text="完成"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="LaterBtn" Content="稍后提醒"
                                Style="{StaticResource UiBtnSecondary}"
                                Padding="20,10" MinWidth="100" FontSize="14"
                                Margin="10,0,0,0"
                                Click="Later_OnClick"/>
                    </StackPanel>

                    <TextBlock x:Name="StatsText"
                               FontSize="12" Foreground="#8A93A6"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
