<Window x:Class="DesktopAssistant.ResourceMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="资源监控"
        Width="330"
        Height="250"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="{StaticResource BrushSurface}"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown">
    <Border x:Name="RootBorder" Margin="10" BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="1" CornerRadius="10" Padding="12">
        <StackPanel>
            <TextBlock x:Name="TitleText" Text="实时资源监控" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,10"/>

            <TextBlock x:Name="CpuText" Text="CPU: --" Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <ProgressBar x:Name="CpuBar" Height="8" Maximum="100" Margin="0,0,0,10" />

            <TextBlock x:Name="MemText" Text="内存: --" Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <ProgressBar x:Name="MemBar" Height="8" Maximum="100" Margin="0,0,0,10"/>

            <TextBlock x:Name="DiskText" Text="磁盘: --" Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,4"/>
            <ProgressBar x:Name="DiskBar" Height="8" Maximum="100" Margin="0,0,0,10"/>

            <TextBlock x:Name="NetText" Text="网络: ↓ -- / ↑ --"
                       Foreground="{StaticResource BrushTextSecondary}"/>
        </StackPanel>
    </Border>
</Window>
