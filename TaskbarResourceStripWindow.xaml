<Window x:Class="DesktopAssistant.TaskbarResourceStripWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="WidthAndHeight"
        MinWidth="220"
        MaxWidth="520"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown">
    <Border CornerRadius="8" Background="#1F2A44" BorderBrush="#354466" BorderThickness="1" Padding="12,4">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="UpText" Foreground="#86EFAC" FontSize="12" Margin="0,0,14,0"/>
            <TextBlock x:Name="DownText" Foreground="#60A5FA" FontSize="12" Margin="0,0,14,0"/>
            <TextBlock x:Name="CpuText" Foreground="#FBBF24" FontSize="12" Margin="0,0,14,0"/>
            <TextBlock x:Name="MemText" Foreground="#C4B5FD" FontSize="12"/>
        </StackPanel>
    </Border>
</Window>
