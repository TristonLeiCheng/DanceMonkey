<Window x:Class="DesktopAssistant.Views.AgentApprovalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作审批"
        Icon="{StaticResource AppWindowIcon}"
        Width="540" Height="Auto" SizeToContent="Height"
        MinHeight="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrushSurface}"
        ShowInTaskbar="False">
    <Border Padding="16" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="8">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock x:Name="RiskIcon" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TitleText"
                           Text="Agent 请求执行操作"
                           FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Border Background="{StaticResource BrushSurfaceMuted}"
                    BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="1"
                    CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock x:Name="ToolText"
                               FontSize="12" Foreground="{StaticResource BrushTextSecondary}"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="SummaryText"
                               FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBox x:Name="DetailsBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     MaxHeight="180"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="#F8F9FC"
                     BorderBrush="{StaticResource BrushBorderSubtle}"
                     Padding="8"
                     Visibility="Collapsed"
                     Margin="0,0,0,12"/>

            <TextBlock x:Name="HintText"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{StaticResource BrushTextSecondary}"
                       Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="拒绝"
                        Style="{StaticResource UiBtnSecondary}"
                        MinWidth="80" Margin="0,0,8,0"
                        Click="Reject_OnClick"/>
                <Button Content="仅此次允许"
                        Style="{StaticResource UiBtnSecondary}"
                        MinWidth="100" Margin="0,0,8,0"
                        Click="AllowOnce_OnClick"/>
                <Button x:Name="AllowScopeBtn"
                        Content="本会话同类都允许"
                        Style="{StaticResource UiBtnSecondary}"
                        MinWidth="140" Margin="0,0,8,0"
                        Click="AllowScope_OnClick"/>
                <Button Content="允许"
                        Style="{StaticResource UiBtnPrimary}"
                        MinWidth="80"
                        IsDefault="True"
                        Click="AllowOnce_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
