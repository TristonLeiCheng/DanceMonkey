<UserControl x:Class="DesktopAssistant.Views.AiChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="AiChatToolbarButton" TargetType="Button" BasedOn="{StaticResource UiBtnSecondary}">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style x:Key="AiChatToolbarPrimaryButton" TargetType="Button" BasedOn="{StaticResource UiBtnPrimary}">
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style x:Key="AiChatAgentToggleButton" TargetType="Button" BasedOn="{StaticResource AiChatToolbarButton}">
            <Style.Triggers>
                <Trigger Property="Tag" Value="On">
                    <Setter Property="Background" Value="{StaticResource BrushChatAccentSoft}"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushChatAccentPressed}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AiChatModeButton" TargetType="Button" BasedOn="{StaticResource UiBtnSecondary}">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="28"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="Active">
                    <Setter Property="Background" Value="{StaticResource BrushSurfaceMuted}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BrushBorderFocus}"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AiChatComboBox" TargetType="ComboBox" BasedOn="{StaticResource UiComboBox}">
            <Setter Property="Padding" Value="10,6,32,6"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="AiChatComposerInput" TargetType="TextBox" BasedOn="{StaticResource UiTextBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,4"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="14,10,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BrushChatSurface}"
                BorderBrush="{StaticResource BrushChatBorderSubtle}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="12,8"
                Margin="0,0,0,10">
            <StackPanel>
                <DockPanel Margin="0,0,0,6" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="AI 工作区"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushChatTextSecondary}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button x:Name="ChatModeChatBtn" Content="对话" Tag="Active"
                                Style="{StaticResource AiChatModeButton}" Click="ChatModeChatBtn_OnClick"/>
                        <Button x:Name="ChatModeTranslateBtn" Content="翻译"
                                Style="{StaticResource AiChatModeButton}" Click="ChatModeTranslateBtn_OnClick"/>
                        <Button x:Name="ChatModeEmailBtn" Content="写邮件"
                                Style="{StaticResource AiChatModeButton}" Click="ChatModeEmailBtn_OnClick"/>
                    </StackPanel>
                </DockPanel>
            <Expander x:Name="PromptExpander" IsExpanded="False" BorderThickness="0" Background="Transparent" Padding="0">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource AiChat.PromptConfig}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushChatTextSecondary}"/>
                        <TextBlock Text=" · 系统提示词与快捷模板"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushChatTextMuted}"/>
                    </StackPanel>
                </Expander.Header>
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PromptSnippetCombo" Grid.Column="0" Style="{StaticResource AiChatComboBox}" Margin="0"/>
                        <Button Grid.Column="2"
                                Content="{DynamicResource AiChat.ApplySnippet}"
                                Style="{StaticResource AiChatToolbarButton}"
                                Margin="0"
                                Click="ApplySnippetBtn_OnClick"/>
                    </Grid>
                    <TextBox x:Name="SystemPromptBox"
                             Grid.Row="1"
                             Style="{StaticResource UiTextBox}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="64"
                             MaxHeight="128"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="12.5"/>
                </Grid>
            </Expander>
            </StackPanel>
        </Border>

        <Border x:Name="ChatContentPanel"
                Grid.Row="1"
                Background="{StaticResource BrushChatSurface}"
                BorderBrush="{StaticResource BrushChatBorder}"
                BorderThickness="1"
                CornerRadius="18"
                Margin="0,0,0,10"
                MinHeight="240"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.07" Color="#2D2A26"/>
            </Border.Effect>
            <Grid>
                <Border Height="38"
                        VerticalAlignment="Top"
                        Background="#FBFAF6"
                        BorderBrush="{StaticResource BrushChatBorderSubtle}"
                        BorderThickness="0,0,0,1">
                    <DockPanel Margin="14,0" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="AI 对话"
                                       FontWeight="SemiBold"
                                       FontSize="12.5"
                                       Foreground="{StaticResource BrushChatTextPrimary}"/>
                            <TextBlock Text=" · WebView 渲染"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushChatTextMuted}"/>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Enter 发送 · Shift+Enter 换行 · Ctrl+V 截图"
                                   FontSize="11.5"
                                   Foreground="{StaticResource BrushChatTextMuted}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
                <wv2:WebView2 x:Name="ChatWeb" Margin="0,38,0,0"/>
            </Grid>
        </Border>

        <Border x:Name="TranslateContentPanel"
                Grid.Row="1"
                Background="{StaticResource BrushChatSurface}"
                BorderBrush="{StaticResource BrushChatBorder}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,0,10"
                Visibility="Collapsed">
            <StackPanel>
                <DockPanel Margin="0,0,0,12" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="翻译" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,2"/>
                        <TextBlock Text="使用当前 AI 模型快速翻译文本" Style="{StaticResource UiHint}"/>
                    </StackPanel>
                    <Button DockPanel.Dock="Right" Content="复制译文" Style="{StaticResource UiBtnSecondary}"
                            Padding="12,6" Click="TranslateCopyResultBtn_OnClick"/>
                </DockPanel>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="TranslateSourceLangCombo" Grid.Column="0" Style="{StaticResource AiChatComboBox}">
                        <ComboBoxItem Content="自动检测" Tag="auto" IsSelected="True"/>
                        <ComboBoxItem Content="中文（简体）" Tag="zh"/>
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="日本語" Tag="ja"/>
                        <ComboBoxItem Content="Deutsch" Tag="de"/>
                        <ComboBoxItem Content="Français" Tag="fr"/>
                        <ComboBoxItem Content="Español" Tag="es"/>
                        <ComboBoxItem Content="한국어" Tag="ko"/>
                    </ComboBox>
                    <Button Grid.Column="1" Content="⇄" Style="{StaticResource UiBtnSecondary}"
                            Padding="12,7" Margin="6,0,14,8" Click="TranslateSwapLangBtn_OnClick"/>
                    <ComboBox x:Name="TranslateTargetLangCombo" Grid.Column="2" Style="{StaticResource AiChatComboBox}">
                        <ComboBoxItem Content="中文（简体）" Tag="zh"/>
                        <ComboBoxItem Content="English" Tag="en" IsSelected="True"/>
                        <ComboBoxItem Content="日本語" Tag="ja"/>
                        <ComboBoxItem Content="Deutsch" Tag="de"/>
                        <ComboBoxItem Content="Français" Tag="fr"/>
                        <ComboBoxItem Content="Español" Tag="es"/>
                        <ComboBoxItem Content="한국어" Tag="ko"/>
                    </ComboBox>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock DockPanel.Dock="Left" Text="原文" Style="{StaticResource UiFieldLabel}"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="粘贴" Style="{StaticResource UiBtnSecondary}" Padding="10,5" Margin="0,0,6,0"
                                        Click="TranslatePasteBtn_OnClick"/>
                                <Button Content="清空" Style="{StaticResource UiBtnSecondary}" Padding="10,5"
                                        Click="TranslateClearBtn_OnClick"/>
                            </StackPanel>
                        </DockPanel>
                        <TextBox x:Name="TranslateSourceText" Style="{StaticResource UiTextBox}"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="260"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="译文" Style="{StaticResource UiFieldLabel}" Margin="0,0,0,6"/>
                        <TextBox x:Name="TranslateResultText" Style="{StaticResource UiResultBox}"
                                 MinHeight="260" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Grid>

                <Button x:Name="TranslateRunBtn" Content="翻译" Style="{StaticResource UiBtnPrimary}"
                        HorizontalAlignment="Right" MinWidth="120" Margin="0,12,0,0"
                        Click="TranslateRunBtn_OnClick"/>
            </StackPanel>
        </Border>

        <Border x:Name="EmailContentPanel"
                Grid.Row="1"
                Background="{StaticResource BrushChatSurface}"
                BorderBrush="{StaticResource BrushChatBorder}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                Margin="0,0,0,10"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="写邮件" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,2"/>
                    <TextBlock Text="把主题和要点整理成专业邮件" Style="{StaticResource UiHint}" Margin="0,0,0,12"/>

                    <TextBlock Text="邮件类型" Style="{StaticResource UiFieldLabel}"/>
                    <ComboBox x:Name="EmailTypeCombo" Style="{StaticResource AiChatComboBox}">
                        <ComboBoxItem Content="商务邮件" IsSelected="True"/>
                        <ComboBoxItem Content="正式邮件"/>
                        <ComboBoxItem Content="日常邮件"/>
                        <ComboBoxItem Content="道歉邮件"/>
                        <ComboBoxItem Content="感谢邮件"/>
                        <ComboBoxItem Content="邀请邮件"/>
                        <ComboBoxItem Content="跟进邮件"/>
                    </ComboBox>

                    <TextBlock Text="语气风格" Style="{StaticResource UiFieldLabel}"/>
                    <ComboBox x:Name="EmailToneCombo" Style="{StaticResource AiChatComboBox}">
                        <ComboBoxItem Content="专业" IsSelected="True"/>
                        <ComboBoxItem Content="友好"/>
                        <ComboBoxItem Content="正式"/>
                        <ComboBoxItem Content="轻松"/>
                    </ComboBox>

                    <TextBlock Text="邮件主题" Style="{StaticResource UiFieldLabel}"/>
                    <TextBox x:Name="EmailSubjectText" Style="{StaticResource UiTextBox}" Margin="0,0,0,10"/>

                    <TextBlock Text="关键要点" Style="{StaticResource UiFieldLabel}"/>
                    <TextBox x:Name="EmailPointsText" Style="{StaticResource UiTextBox}"
                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="180"
                             VerticalScrollBarVisibility="Auto"/>

                    <Button x:Name="EmailGenerateBtn" Content="生成邮件" Style="{StaticResource UiBtnPrimary}"
                            HorizontalAlignment="Right" MinWidth="120" Margin="0,12,0,0"
                            Click="EmailGenerateBtn_OnClick"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="输出预览" Style="{StaticResource UiSectionTitle}"/>
                        <Button DockPanel.Dock="Right" Content="复制全文" Style="{StaticResource UiBtnSecondary}"
                                Padding="12,6" Click="EmailCopyBtn_OnClick"/>
                    </DockPanel>
                    <TextBox x:Name="EmailResultText" Style="{StaticResource UiResultBox}"
                             MinHeight="420" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Grid>
        </Border>

        <WrapPanel x:Name="AttachmentChipsHost"
                   Grid.Row="2"
                   Margin="2,0,2,4"
                   Visibility="Collapsed"/>

        <Border x:Name="ChatComposerPanel"
                Grid.Row="3"
                Background="{StaticResource BrushChatSurface}"
                BorderBrush="{StaticResource BrushChatBorder}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="12"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.08" Color="#2D2A26"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBox x:Name="InputBox"
                             MinHeight="64"
                             MaxHeight="142"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource AiChatComposerInput}"
                             PreviewKeyDown="InputBox_OnPreviewKeyDown"/>
                    <TextBlock x:Name="InputPlaceholder"
                               Text="输入内容，Enter 发送；Shift+Enter 换行；Ctrl+V 粘贴截图"
                               Foreground="{StaticResource BrushChatTextMuted}"
                               FontSize="12.5"
                               IsHitTestVisible="False"
                               VerticalAlignment="Top"
                               Margin="4,8,4,0"
                               TextWrapping="Wrap"/>
                </Grid>

                <Border Grid.Row="1"
                        Height="1"
                        Background="{StaticResource BrushChatBorderSubtle}"
                        Margin="0,10,0,10"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                        <Button x:Name="AgentModeBtn"
                                Style="{StaticResource AiChatAgentToggleButton}"
                                Click="AgentModeBtn_OnClick"
                                ToolTip="启用或关闭 Agent 模式">
                            <TextBlock x:Name="AgentModeBtnText" Text="Agent: Off"/>
                        </Button>
                        <ComboBox x:Name="AgentPermCombo"
                                  Style="{StaticResource AiChatComboBox}"
                                  Width="102"
                                  Visibility="Collapsed"
                                  SelectionChanged="AgentPermCombo_OnSelectionChanged">
                            <ComboBoxItem Content="Plan" Tag="Plan"/>
                            <ComboBoxItem Content="Ask" Tag="Ask" IsSelected="True"/>
                            <ComboBoxItem Content="Auto" Tag="Auto"/>
                        </ComboBox>
                        <ComboBox x:Name="AgentWorkflowCombo"
                                  Style="{StaticResource AiChatComboBox}"
                                  Width="148"
                                  Visibility="Collapsed"
                                  SelectionChanged="AgentWorkflowCombo_OnSelectionChanged"/>
                        <ComboBox x:Name="ModelSelectorCombo"
                                  Style="{StaticResource AiChatComboBox}"
                                  Width="168"
                                  ToolTip="切换当前模型；会同步到设置与 CLI 默认模型"
                                  SelectionChanged="ModelSelectorCombo_OnSelectionChanged"/>
                        <Button x:Name="PromptChipBtn"
                                Style="{StaticResource AiChatToolbarButton}"
                                Click="PromptChipBtn_OnClick"
                                ToolTip="查看当前模型 / Prompt 设置">
                            <TextBlock x:Name="ModelChipText" Text="--"/>
                        </Button>
                        <Popup x:Name="PromptPopup"
                               PlacementTarget="{Binding ElementName=PromptChipBtn}"
                               Placement="Top"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{StaticResource BrushSurface}"
                                    BorderBrush="{StaticResource BrushBorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14"
                                    MaxWidth="340">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.16" Color="#2D2A26"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="当前模型 / Prompt"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="模型状态显示在按钮上；系统 Prompt 可在上方 Prompt 配置区编辑。"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               FontSize="12"/>
                                    <Button Content="完成"
                                            Style="{StaticResource UiBtnSecondary}"
                                            HorizontalAlignment="Right"
                                            Padding="10,5"
                                            Margin="0,10,0,0"
                                            Click="PromptDoneBtn_OnClick"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                        <Button Content="{DynamicResource AiChat.AddFiles}"
                                Style="{StaticResource AiChatToolbarButton}"
                                Click="AddFilesBtn_OnClick"/>
                        <Button x:Name="MoreActionsBtn"
                                Content="··· 更多"
                                Style="{StaticResource AiChatToolbarButton}"
                                Click="MoreActionsBtn_OnClick"
                                ToolTip="摘要剪贴板、音频转写、导出笔记、清空">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="MoreActionsMenu"
                                             Background="{StaticResource BrushSurface}"
                                             BorderBrush="{StaticResource BrushBorderSubtle}">
                                    <MenuItem Header="摘要剪贴板内容" Click="SummarizeClipBtn_OnClick"/>
                                    <MenuItem Header="转写音频文件…" Click="SttBtn_OnClick"/>
                                    <Separator/>
                                    <MenuItem Header="导出对话为笔记" Click="ExportBtn_OnClick"/>
                                    <MenuItem Header="清空对话" Click="ClearBtn_OnClick"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </WrapPanel>

                    <WrapPanel Grid.Column="1"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right">
                        <Button x:Name="StopBtn"
                                Content="{DynamicResource AiChat.Stop}"
                                Style="{StaticResource AiChatToolbarButton}"
                                Visibility="Collapsed"
                                Click="StopBtn_OnClick"/>
                        <Button x:Name="RegenerateBtn"
                                Content="↺ 重新生成"
                                Style="{StaticResource AiChatToolbarButton}"
                                Visibility="Collapsed"
                                Click="RegenerateBtn_OnClick"
                                ToolTip="重新生成最后一条 AI 回复"/>
                        <Button x:Name="SendBtn"
                                Content="{DynamicResource AiChat.Send}"
                                Style="{StaticResource AiChatToolbarPrimaryButton}"
                                Click="SendBtn_OnClick"/>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
