<UserControl x:Class="DesktopAssistant.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4,0,4,20" MaxWidth="820">
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="智能对话" Style="{StaticResource UiPageTitle}"/>
                <TextBlock Text="自定义系统提示词，与模型自由协作" Style="{StaticResource UiPageSubtitle}"/>
            </StackPanel>

            <Border Style="{StaticResource UiCard}">
                <StackPanel>
                    <TextBlock Text="对话上下文" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,16"/>

                    <TextBlock Text="系统提示词（可选）" Style="{StaticResource UiFieldLabel}"/>
                    <TextBlock Text="定义角色、格式或约束，留空则使用默认助手人设；可从下方「常用 Prompt」快速填入" Style="{StaticResource UiHint}" Margin="0,-2,0,6"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PromptSnippetCombo" Grid.Column="0" Style="{StaticResource UiComboBox}"
                                  SelectionChanged="PromptSnippetCombo_OnSelectionChanged"/>
                        <Button Grid.Column="2" Content="应用所选" Style="{StaticResource UiBtnSecondary}"
                                Padding="14,8" Click="ApplySnippetBtn_OnClick"/>
                    </Grid>
                    <TextBox x:Name="SystemPrompt" Style="{StaticResource UiTextBox}" TextWrapping="Wrap"
                             AcceptsReturn="True" MinHeight="90" Margin="0,0,0,16"/>

                    <TextBlock Text="你的输入" Style="{StaticResource UiFieldLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="从剪贴板填入" Style="{StaticResource UiBtnSecondary}" Padding="12,7" Margin="0,0,8,0"
                                Click="PasteFromClipboard_OnClick"/>
                        <Button x:Name="SummarizeClipboardBtn" Content="摘要剪贴板内容" Style="{StaticResource UiBtnAccentBlue}"
                                Padding="12,7" Click="SummarizeClipboard_OnClick"/>
                    </StackPanel>
                    <TextBox x:Name="UserInput" Style="{StaticResource UiTextBox}" TextWrapping="Wrap"
                             AcceptsReturn="True" MinHeight="180" Margin="0,0,0,20"/>

                    <Button x:Name="SubmitBtn" Content="发送请求" Style="{StaticResource UiBtnPrimary}"
                            HorizontalAlignment="Stretch" Click="SubmitBtn_OnClick"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource UiCard}">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <TextBlock Text="模型回复" Style="{StaticResource UiSectionTitle}" VerticalAlignment="Center"/>
                        <Button x:Name="CopyBtn" Content="复制全文" Style="{StaticResource UiBtnAccentBlue}"
                                HorizontalAlignment="Right" Padding="16,8" Click="CopyBtn_OnClick"/>
                    </Grid>
                    <TextBox x:Name="ResultText" Style="{StaticResource UiResultBox}" MinHeight="200"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
