<UserControl x:Class="DesktopAssistant.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0">
        <StackPanel Margin="4,0,4,20" MaxWidth="820">
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="电脑清理" Style="{StaticResource UiPageTitle}"/>
                <TextBlock Text="仅清理白名单临时目录；执行前请确认勾选项" Style="{StaticResource UiPageSubtitle}"/>
            </StackPanel>

            <Border Style="{StaticResource UiCard}">
                <StackPanel>
                    <TextBlock Text="清理目标" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="TargetsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}"
                                          Margin="0,5,0,5"
                                          FontSize="13.5"
                                          Foreground="{StaticResource BrushTextPrimary}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding RootPath}" Style="{StaticResource UiHint}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <Button x:Name="AnalyzeBtn" Content="分析体积" Style="{StaticResource UiBtnSecondary}"
                                MinWidth="110" Margin="0,0,10,0" Click="AnalyzeBtn_OnClick"/>
                        <Button x:Name="CleanBtn" Content="执行清理" Style="{StaticResource UiBtnPrimary}"
                                MinWidth="110" Click="CleanBtn_OnClick"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource UiCard}">
                <StackPanel>
                    <TextBlock Text="分析结果 / 日志" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,12"/>
                    <TextBox x:Name="LogBox" Style="{StaticResource UiResultBox}" MinHeight="200"
                             IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
