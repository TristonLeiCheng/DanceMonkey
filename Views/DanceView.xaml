<UserControl x:Class="DesktopAssistant.Views.DanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <!-- 动物卡片基础样式 -->
        <Style x:Key="AnimalCard" TargetType="Border">
            <Setter Property="Width" Value="88"/>
            <Setter Property="Height" Value="96"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{StaticResource BrushSurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <!-- 选中状态样式 -->
        <Style x:Key="AnimalCardSelected" TargetType="Border" BasedOn="{StaticResource AnimalCard}">
            <Setter Property="Background" Value="{StaticResource BrushAccentMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="2.5"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0">
        <StackPanel Margin="4,0,4,20" MaxWidth="1180" HorizontalAlignment="Stretch">
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="桌面宠物" Style="{StaticResource UiPageTitle}"/>
                <TextBlock Text="右下角桌面宠物（替代悬浮球），支持外形、大小、互动提醒和防休眠设置" Style="{StaticResource UiPageSubtitle}"/>
            </StackPanel>

            <!-- ═══ 桌面宠物卡片 ═══ -->
            <Border Style="{StaticResource UiCard}">
                <StackPanel>
                    <TextBlock Text="桌面宠物模式" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,10"/>
                    <CheckBox x:Name="PetModeCheck"
                              Content="启用桌面宠物模式（屏幕右下角显示，替代桌面悬浮球）"
                              FontSize="13"
                              Foreground="{StaticResource BrushTextPrimary}"
                              Margin="0,0,0,14"/>
                    <CheckBox x:Name="PetPreventSleepCheck"
                              Content="宠物模式开启时阻止计算机空闲休眠 / 关闭显示器"
                              FontSize="13"
                              Foreground="{StaticResource BrushTextPrimary}"
                              Margin="0,0,0,14"
                              IsChecked="True"/>

                    <TextBlock Text="宠物外形" Style="{StaticResource UiFieldLabel}"/>
                    <TextBlock Style="{StaticResource UiHint}" Margin="0,0,0,12">
                        每种宠物有独立的简单循环动画。可拖动位置；单击打开主窗口，单击宠物会弹出气泡互动。
                    </TextBlock>

                    <!-- 动物选择器 -->
                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border x:Name="AnimalCard_human" Tag="human"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_human"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="小助手" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_cat" Tag="cat"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_cat"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="猫咪" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_dog" Tag="dog"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_dog"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="狗狗" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_rabbit" Tag="rabbit"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_rabbit"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="兔子" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_fox" Tag="fox"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_fox"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="狐狸" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_goose" Tag="goose"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_goose"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="大鹅" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_cockroach" Tag="cockroach"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_cockroach"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="蟑螂" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_mosquito" Tag="mosquito"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_mosquito"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="蚊子" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_capybara" Tag="capybara"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_capybara"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="卡皮巴拉" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_frog" Tag="frog"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_frog"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="青蛙" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_penguin" Tag="penguin"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_penguin"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="企鹅" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_turtle" Tag="turtle"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_turtle"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="乌龟" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AnimalCard_hedgehog" Tag="hedgehog"
                                Style="{StaticResource AnimalCard}"
                                MouseLeftButtonDown="AnimalCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                <Image x:Name="AnimalPreview_hedgehog"
                                       Width="38" Height="38" HorizontalAlignment="Center" Margin="0,4,0,4"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Text="刺猬" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushTextSecondary}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <TextBlock TextWrapping="Wrap" Style="{StaticResource UiHint}" Margin="0,0,0,12">
                        开启宠物模式后，桌面悬浮球会被隐藏，由右下角宠物接管快捷入口（双击打开主窗口、单击互动、右键菜单等）。防休眠可按需单独开启或关闭。
                    </TextBlock>
                    <TextBlock Text="宠物大小" Style="{StaticResource UiFieldLabel}" Margin="0,4,0,6"/>
                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton x:Name="PetSize_Small"  Content="小 (48px)"   GroupName="PetSize" Margin="0,0,16,4" FontSize="13" Foreground="{StaticResource BrushTextPrimary}" VerticalContentAlignment="Center"/>
                        <RadioButton x:Name="PetSize_Medium" Content="中 (68px)"   GroupName="PetSize" Margin="0,0,16,4" FontSize="13" Foreground="{StaticResource BrushTextPrimary}" VerticalContentAlignment="Center" IsChecked="True"/>
                        <RadioButton x:Name="PetSize_Large"  Content="大 (96px)"   GroupName="PetSize" Margin="0,0,16,4" FontSize="13" Foreground="{StaticResource BrushTextPrimary}" VerticalContentAlignment="Center"/>
                        <RadioButton x:Name="PetSize_XLarge" Content="超大 (128px)" GroupName="PetSize" Margin="0,0,0,4"  FontSize="13" Foreground="{StaticResource BrushTextPrimary}" VerticalContentAlignment="Center"/>
                    </WrapPanel>

                    <Button x:Name="SavePetBtn" Content="保存宠物设置" Style="{StaticResource UiBtnPrimary}"
                            HorizontalAlignment="Stretch" Click="SavePetBtn_OnClick"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
