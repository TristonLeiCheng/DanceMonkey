<UserControl x:Class="DesktopAssistant.Views.FileManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushPageBg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 左侧：文件浏览器 ═══ -->
        <Border Grid.Column="0" Background="{StaticResource BrushSurface}" CornerRadius="10" Padding="0" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <Border Grid.Row="0" Padding="14,12" BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource FM.SandboxFiles}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="{DynamicResource FM.Refresh}" Style="{StaticResource UiBtnSecondary}" Padding="6,4"
                                FontSize="12" ToolTip="{DynamicResource FM.Refresh}" Click="BtnRefreshTree_OnClick"/>
                    </Grid>
                </Border>

                <!-- 路径导航 -->
                <Border Grid.Row="1" Padding="10,8" Background="{StaticResource BrushSurfaceMuted}">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnNavUp" Content="{DynamicResource FM.NavUp}" Style="{StaticResource UiBtnSecondary}" Padding="6,3"
                                FontSize="11" ToolTip="{DynamicResource FM.GoUp}" Click="BtnNavUp_OnClick" Margin="0,0,6,0"/>
                        <TextBlock x:Name="CurrentPathText" Text="/" Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="11.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <!-- 文件列表 -->
                <ListBox x:Name="FileListBox" Grid.Row="2" Background="Transparent" BorderThickness="0"
                         Padding="4,4" FontSize="12.5"
                         MouseDoubleClick="FileListBox_OnDoubleClick"
                         SelectionChanged="FileListBox_OnSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,3">
                                <TextBlock Text="{Binding TypeDisplay}" Width="28" FontSize="14" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource BrushTextPrimary}"/>
                                    <TextBlock FontSize="10.5" Foreground="{StaticResource BrushTextMuted}">
                                        <Run Text="{Binding SizeDisplay, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{Binding ModifiedDisplay, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 底部状态 + 操作 -->
                <Border Grid.Row="3" Padding="10,8" BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <TextBlock x:Name="StatsText" Text="0 个文件，0 个文件夹" FontSize="11"
                                   Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource FM.View}" Style="{StaticResource UiBtnSecondary}" Padding="8,4" FontSize="11"
                                    Margin="0,0,4,0" Click="BtnViewFile_OnClick"/>
                            <Button Content="{DynamicResource FM.Delete}" Style="{StaticResource UiBtnSecondary}" Padding="8,4" FontSize="11"
                                    Margin="0,0,4,0" Click="BtnDeleteSelected_OnClick"/>
                            <Button Content="{DynamicResource FM.OpenDir}" Style="{StaticResource UiBtnSecondary}" Padding="8,4" FontSize="11"
                                    Click="BtnOpenSandbox_OnClick"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ 右侧：AI 指令面板 ═══ -->
        <Border Grid.Column="1" Background="{StaticResource BrushSurface}" CornerRadius="10" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <Border Grid.Row="0" Padding="16,12" BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource FM.AiTitle}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Text="{DynamicResource FM.AiDesc}"
                                   FontSize="11.5" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 对话/结果区 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="ResultBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             Background="Transparent" BorderThickness="0" Padding="16,12"
                             FontSize="13" FontFamily="Consolas, Microsoft YaHei"
                             Foreground="{StaticResource BrushTextPrimary}"
                             VerticalAlignment="Top"
                             Text=""/>
                </ScrollViewer>

                <!-- 输入区 -->
                <Border Grid.Row="2" Padding="12,10" BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputBox" Grid.Column="0" Style="{StaticResource UiTextBox}"
                                     AcceptsReturn="False" FontSize="13"
                                     VerticalContentAlignment="Center"
                                     KeyDown="InputBox_OnKeyDown"/>
                            <Button x:Name="BtnSend" Grid.Column="1" Content="{DynamicResource FM.Send}" Style="{StaticResource UiBtnPrimary}"
                                    Padding="14,8" FontSize="12.5" Margin="8,0,0,0"
                                    Click="BtnSend_OnClick"/>
                        </Grid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="{DynamicResource FM.QuickList}" Style="{StaticResource UiBtnSecondary}" Padding="10,5" FontSize="11"
                                    Margin="0,0,6,0" Click="BtnQuickList_OnClick"/>
                            <Button Content="{DynamicResource FM.ClearChat}" Style="{StaticResource UiBtnSecondary}" Padding="10,5" FontSize="11"
                                    Margin="0,0,6,0" Click="BtnClearResult_OnClick"/>
                            <TextBlock x:Name="StatusText" Text="" Foreground="{StaticResource BrushTextMuted}"
                                       FontSize="11.5" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
