<UserControl x:Class="DesktopAssistant.Views.FileToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="4,0,4,16">
        <TabControl Padding="0,8,0,0" BorderThickness="0">
            <TabItem Header="文件检索">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="在指定文件夹内按关键字搜索（匹配文件名与完整路径）。结果有上限，避免扫描过久。"
                                   Style="{StaticResource UiHint}"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SearchFolderBox" Style="{StaticResource UiTextBox}" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="选择文件夹…" Style="{StaticResource UiBtnSecondary}" Margin="8,0,0,0"
                                    Padding="12,8" Click="SearchPickFolder_OnClick"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="关键字（匹配文件名/路径，留空列出全部）" Style="{StaticResource UiFieldLabel}" TextWrapping="Wrap"/>
                                <TextBox x:Name="SearchKeywordBox" Style="{StaticResource UiTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Bottom">
                                <TextBlock Text="最多条数" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="SearchMaxBox" Style="{StaticResource UiTextBox}" Width="84" Text="500"/>
                            </StackPanel>
                        </Grid>
                        <CheckBox x:Name="SearchSubfoldersCheck" Margin="0,0,0,10">
                            <TextBlock Text="包含子文件夹（目录较大时会更慢）" TextWrapping="Wrap"/>
                        </CheckBox>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="BtnSearchRun" Content="开始搜索" Style="{StaticResource UiBtnPrimary}" Padding="16,8"
                                    Click="BtnSearchRun_OnClick"/>
                            <TextBlock x:Name="SearchStatusText" VerticalAlignment="Center" Margin="12,0,0,0"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                    <DataGrid x:Name="SearchResultGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" MinHeight="280"
                              MouseDoubleClick="SearchResultGrid_OnMouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="文件名" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="源文件夹" Binding="{Binding FolderDisplay}" Width="2*"/>
                            <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedDisplay}" Width="150"/>
                            <DataGridTextColumn Header="修改时间" Binding="{Binding ModifiedDisplay}" Width="150"/>
                            <DataGridTextColumn Header="大小" Binding="{Binding SizeDisplay}" Width="100"/>
                            <DataGridTextColumn Header="完整路径" Binding="{Binding FullPath}" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="批量重命名">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,12,0,0" MaxWidth="800">
                        <TextBlock Text="对同一文件夹内、已列出的文件按规则生成新文件名。请先「列出文件」再预览、应用。"
                                   Style="{StaticResource UiHint}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <TextBlock Text="文件夹" Style="{StaticResource UiFieldLabel}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RenameFolderBox" Style="{StaticResource UiTextBox}" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="选择…" Style="{StaticResource UiBtnSecondary}" Margin="8,0,0,0"
                                    Padding="12,8" Click="RenamePickFolder_OnClick"/>
                        </Grid>

                        <TextBlock Text="匹配模式（如 * 或 *.pdf）" Style="{StaticResource UiFieldLabel}"/>
                        <TextBox x:Name="RenamePatternBox" Style="{StaticResource UiTextBox}" Text="*" Margin="0,0,0,8"/>
                        <CheckBox x:Name="RenameSubfoldersCheck" Content="包含子文件夹" Margin="0,0,0,10"/>
                        <Button Content="列出文件" Style="{StaticResource UiBtnSecondary}" HorizontalAlignment="Left" Padding="14,8"
                                Click="RenameListFiles_OnClick"/>
                        <TextBlock x:Name="RenameListHint" Text="尚未列出文件" Style="{StaticResource UiHint}" Margin="0,8,0,12"/>

                        <TextBlock Text="主文件名：前缀 / 后缀（不含扩展名）" Style="{StaticResource UiFieldLabel}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RenamePrefixBox" Style="{StaticResource UiTextBox}"/>
                            <TextBox x:Name="RenameSuffixBox" Grid.Column="2" Style="{StaticResource UiTextBox}"/>
                        </Grid>

                        <TextBlock Text="在主文件名中查找 / 替换（可选）" Style="{StaticResource UiFieldLabel}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RenameFindBox" Style="{StaticResource UiTextBox}"/>
                            <TextBox x:Name="RenameReplaceBox" Grid.Column="2" Style="{StaticResource UiTextBox}"/>
                        </Grid>

                        <CheckBox x:Name="RenameIndexCheck" Content="添加序号（前缀+序号+_+原名+后缀；若无前后缀则为 序号_原名）" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="序号位数" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="RenameDigitsBox" Width="48" Style="{StaticResource UiTextBox}" Text="3"/>
                            <TextBlock Text="起始值" VerticalAlignment="Center" Margin="16,0,8,0"/>
                            <TextBox x:Name="RenameStartBox" Width="48" Style="{StaticResource UiTextBox}" Text="1"/>
                        </StackPanel>

                        <Button Content="生成预览" Style="{StaticResource UiBtnPrimary}" HorizontalAlignment="Left" Padding="16,8"
                                Margin="0,0,0,12" Click="RenamePreview_OnClick"/>

                        <DataGrid x:Name="RenamePreviewGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                  MaxHeight="220" Margin="0,0,0,12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="原文件名" Binding="{Binding OldName}" Width="*"/>
                                <DataGridTextColumn Header="新文件名" Binding="{Binding NewName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button x:Name="BtnRenameApply" Content="应用重命名" Style="{StaticResource UiBtnSuccess}" HorizontalAlignment="Left"
                                Padding="18,10" Click="BtnRenameApply_OnClick"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
