<Window x:Class="DesktopAssistant.Views.FolderPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择目标文件夹" Height="420" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrushPageBg}">
    <Border Padding="16" Background="{StaticResource BrushPageBg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="HintText" Grid.Row="0" Margin="0,0,0,10" FontSize="13"
                       Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap"/>

            <Border Grid.Row="1" BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="1"
                    CornerRadius="8" Background="{StaticResource BrushSurface}" Padding="4">
                <TreeView x:Name="FolderTree" BorderThickness="0" Background="Transparent"
                          SelectedItemChanged="FolderTree_OnSelectedItemChanged">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                            <Setter Property="Padding" Value="2,1"/>
                        </Style>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="移动到此" Style="{StaticResource UiBtnPrimary}" MinWidth="90" Margin="0,0,8,0"
                        x:Name="OkBtn" IsEnabled="False" Click="Ok_OnClick"/>
                <Button Content="取消" Style="{StaticResource UiBtnSecondary}" MinWidth="90"
                        IsCancel="True" Click="Cancel_OnClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
