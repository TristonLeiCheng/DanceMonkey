<UserControl x:Class="DesktopAssistant.Views.NetworkMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4,0,4,20" MaxWidth="860">
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="网络监控" Style="{StaticResource UiPageTitle}"/>
                <TextBlock Text="本机网卡、外网与业务相关端点的连通性一览" Style="{StaticResource UiPageSubtitle}"/>
            </StackPanel>

            <Border Style="{StaticResource UiCard}">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="StatusTitle" Text="网络状态" Style="{StaticResource UiSectionTitle}" Margin="0"/>
                                <TextBlock x:Name="StatusTime" Style="{StaticResource UiHint}" Margin="0,-2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <CheckBox x:Name="AutoRefreshCheck" Content="每 60 秒自动刷新" VerticalAlignment="Center"
                                      Margin="0,0,14,0" FontSize="12.5" Foreground="{StaticResource BrushTextSecondary}"/>
                            <Button x:Name="RefreshBtn" Content="立即检测" Style="{StaticResource UiBtnPrimary}"
                                    Padding="16,9" Click="RefreshBtn_OnClick"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="BusyText" Text="正在检测…" Visibility="Collapsed"
                               Foreground="{StaticResource BrushTextMuted}" FontSize="12.5" Margin="0,0,0,6"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource UiCard}">
                <StackPanel>
                    <TextBlock Text="活动网卡" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="AdapterList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="14,12" CornerRadius="8"
                                        Background="{StaticResource BrushSurfaceMuted}"
                                        BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13.5"
                                                       Foreground="{StaticResource BrushTextPrimary}"/>
                                            <TextBlock Margin="0,3,0,0" FontSize="12" Foreground="{StaticResource BrushTextSecondary}"
                                                       Text="{Binding TypeAndIp}"/>
                                            <TextBlock Margin="0,2,0,0" FontSize="12" Foreground="{StaticResource BrushTextMuted}"
                                                       Text="{Binding SpeedLine}"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="6" Padding="10,4" VerticalAlignment="Top"
                                                Background="#ECFDF5">
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Medium" Foreground="#059669"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="NoAdapterText" Text="未检测到已连接的非环回网卡。" Visibility="Collapsed"
                               Foreground="{StaticResource BrushTextMuted}" FontSize="12.5"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource UiCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="连通性探测" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,4"/>
                    <TextBlock Text="ICMP 与 HTTPS 探测受防火墙与代理策略影响，结果仅供参考。" Style="{StaticResource UiHint}" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="ProbeList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="14,12" CornerRadius="8"
                                        BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource BrushSurfaceMuted}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Ok}" Value="False">
                                                    <Setter Property="Background" Value="#FEF2F2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="8" Height="8" Margin="0,5,12,0" VerticalAlignment="Top">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#10B981"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Ok}" Value="False">
                                                            <Setter Property="Fill" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="13.5"
                                                       Foreground="{StaticResource BrushTextPrimary}"/>
                                            <TextBlock Text="{Binding Detail}" Margin="0,3,0,0" FontSize="12"
                                                       Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
