<Window x:Class="DesktopAssistant.Views.NoteAiResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 结果预览"
        Width="940" Height="620" MinWidth="640" MinHeight="440"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6FA"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 顶部标题栏 ── -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="18,13,18,13"
                BorderBrush="#F0F1F5" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F0EEFF" CornerRadius="6" Padding="8,3" Margin="0,0,10,0">
                        <TextBlock Text="✨ AI" FontSize="11" Foreground="#7C5CFC" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock x:Name="ActionTitle" Text="AI 结果预览"
                               FontSize="15" FontWeight="SemiBold" Foreground="#1A1D26"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="StatusBadge" Background="#FEF3C7" CornerRadius="5" Padding="9,4">
                        <TextBlock x:Name="StatusText" Text="生成中…" FontSize="11" Foreground="#B45309"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 内容区：原文 | AI 结果 ── -->
        <Grid Grid.Row="1" Margin="14,14,14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- 原文面板 -->
            <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True"
                    BorderBrush="#EDEFF5" BorderThickness="1"
                    Background="#F8F9FC">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="13,7,13,7"
                            Background="#FFFFFF" BorderBrush="#EDEFF5" BorderThickness="0,0,0,1">
                        <TextBlock Text="原 文" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#6B7084"/>
                    </Border>
                    <TextBox x:Name="OriginalBox" IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="12.5" Background="Transparent"
                             BorderThickness="0" Padding="14,12"
                             Foreground="#4A5068"
                             SelectionBrush="#C7D0FF"/>
                </DockPanel>
            </Border>

            <!-- 分隔条 -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- AI 结果面板 -->
            <Border Grid.Column="2" CornerRadius="10" ClipToBounds="True"
                    BorderBrush="#EDEFF5" BorderThickness="1"
                    Background="#FFFFFF">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="13,7,13,7"
                            Background="#F8F9FF" BorderBrush="#EDEFF5" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="ResultPanelLabel" Text="AI 结果"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#4F6EF7"/>
                    </Border>
                    <TextBox x:Name="ResultBox"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="12.5" Background="Transparent"
                             BorderThickness="0" Padding="14,12"
                             Foreground="#1A1D26"
                             CaretBrush="#4F6EF7"
                             SelectionBrush="#C7D0FF"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ── 底部操作栏 ── -->
        <Border Grid.Row="2" Padding="18,10,18,14" Background="#FFFFFF"
                BorderBrush="#F0F1F5" BorderThickness="0,1,0,0" Margin="0,10,0,0">
            <Grid>
                <TextBlock x:Name="FooterHint"
                           Text="生成完成后可直接编辑 AI 结果再接受"
                           FontSize="11" Foreground="#9CA0B0" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Content="取消"
                            Padding="16,7" FontSize="12" Margin="0,0,8,0"
                            Click="BtnCancel_OnClick">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource UiBtnSecondary}">
                                <Setter Property="Padding" Value="16,7"/>
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="BtnAppend" Content="追加到文末"
                            IsEnabled="False" Margin="0,0,8,0"
                            Click="BtnAppend_OnClick">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource UiBtnSecondary}">
                                <Setter Property="Padding" Value="16,7"/>
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="BtnAccept" Content="接受替换"
                            IsEnabled="False"
                            Click="BtnAccept_OnClick">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource UiBtnPrimary}">
                                <Setter Property="Padding" Value="16,7"/>
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
