<UserControl x:Class="DesktopAssistant.Views.PasswordVaultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="KeePassHeaderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1B2838" Offset="0"/>
            <GradientStop Color="#2C5282" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="KeePassAccent" Color="#2980B9"/>
    </UserControl.Resources>

    <Grid>
        <!-- 锁定 / 创建库 -->
        <Border x:Name="LockPanel" Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#152238" Offset="0"/>
                    <GradientStop Color="#1E3A5F" Offset="0.5"/>
                    <GradientStop Color="#243B55" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="440">
                <Border Background="#ECEFF4" CornerRadius="12" Padding="28,26"
                        BorderBrush="#BDC3C7" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.35" Color="#000"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="40" Height="40" CornerRadius="8" Background="{StaticResource KeePassAccent}" Margin="0,0,12,0">
                                <TextBlock Text="🔐" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="LockTitle" Text="密码库" FontSize="20" FontWeight="Bold" Foreground="#1A1D26"/>
                                <TextBlock x:Name="LockSubtitle" Text="本地加密存储 · 主密码仅保存在本机内存中" FontSize="11" Foreground="#6B7084" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock x:Name="LblMaster" Text="主密码" FontSize="11" Foreground="#6B7084" Margin="0,16,0,4"/>
                        <PasswordBox x:Name="PwdMaster" Height="36" Padding="10,0" FontSize="13"
                                     BorderBrush="#CED4DA" BorderThickness="1"/>

                        <TextBlock x:Name="LblConfirm" Text="确认主密码" FontSize="11" Foreground="#6B7084" Margin="0,12,0,4" Visibility="Collapsed"/>
                        <PasswordBox x:Name="PwdConfirm" Height="36" Padding="10,0" FontSize="13" Visibility="Collapsed"
                                     BorderBrush="#CED4DA" BorderThickness="1"/>

                        <Button x:Name="BtnUnlock" Content="解锁" Margin="0,22,0,6" Height="40" FontSize="14" FontWeight="SemiBold"
                                Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnUnlock_OnClick">
                            <Button.Background>
                                <SolidColorBrush Color="#2980B9"/>
                            </Button.Background>
                        </Button>

                        <TextBlock x:Name="LockHint" TextWrapping="Wrap" FontSize="10" Foreground="#94A3B8" Margin="0,14,0,0"
                                   Text="数据文件位于笔记目录 Journal 下，使用 PBKDF2 + AES-256-GCM。请牢记主密码，丢失无法找回。"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 已解锁 -->
        <Grid x:Name="VaultPanel" Visibility="Collapsed"
              PreviewMouseDown="VaultPanel_OnActivity"
              PreviewKeyDown="VaultPanel_OnActivity"
              PreviewMouseWheel="VaultPanel_OnActivity">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource KeePassHeaderBrush}" Padding="12,10" CornerRadius="10,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="自动锁定" Foreground="#B8C5D6" VerticalAlignment="Center" Margin="4,0,8,0" FontSize="11"/>
                        <ComboBox x:Name="ComboAutoLock" Width="128" FontSize="11" VerticalAlignment="Center"
                                  SelectionChanged="ComboAutoLock_OnSelectionChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnAdd" Content="＋ 新建" Style="{StaticResource UiBtnPrimary}" Padding="12,6" Margin="0,0,8,0" FontSize="12" Click="BtnAdd_OnClick"/>
                        <Button x:Name="BtnEdit" Content="✏ 编辑" Style="{StaticResource UiBtnSecondary}" Padding="12,6" Margin="0,0,8,0" FontSize="12" Click="BtnEdit_OnClick"/>
                        <Button x:Name="BtnDelete" Content="🗑 删除" Style="{StaticResource UiBtnSecondary}" Padding="12,6" Margin="0,0,8,0" FontSize="12" Click="BtnDelete_OnClick"/>
                        <Button x:Name="BtnCopy" Content="📋 复制密码" Style="{StaticResource UiBtnSecondary}" Padding="12,6" Margin="0,0,8,0" FontSize="12" Click="BtnCopy_OnClick"/>
                        <Button x:Name="BtnChangeMaster" Content="🔑 更改主密码" Style="{StaticResource UiBtnSecondary}" Padding="12,6" Margin="0,0,8,0" FontSize="12" Click="BtnChangeMaster_OnClick"/>
                        <Button x:Name="BtnLock" Content="锁定" Style="{StaticResource UiBtnSecondary}" Padding="12,6" FontSize="12" Click="BtnLock_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210" MinWidth="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#EEF2F7" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="分组" FontWeight="SemiBold" FontSize="12" Foreground="#334155" Margin="12,12,12,6"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="8,0,8,10" HorizontalAlignment="Stretch">
                            <Button Content="＋ 新建" Style="{StaticResource UiBtnSecondary}" Padding="8,5" FontSize="11" Margin="0,0,6,0" Click="BtnNewGroup_OnClick"/>
                            <Button Content="重命名" Style="{StaticResource UiBtnSecondary}" Padding="8,5" FontSize="11" Margin="0,0,6,0" Click="BtnRenameGroup_OnClick"/>
                            <Button Content="删除" Style="{StaticResource UiBtnSecondary}" Padding="8,5" FontSize="11" Click="BtnDeleteGroup_OnClick"/>
                        </StackPanel>
                        <ListBox x:Name="GroupListBox" Margin="8,0,8,8" FontSize="12.5"
                                 SelectionChanged="GroupListBox_OnSelectionChanged"/>
                    </DockPanel>
                </Border>

                <DataGrid x:Name="EntriesGrid" Grid.Column="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          BorderBrush="{StaticResource BrushBorder}"
                          Background="White"
                          RowHeight="32"
                          FontSize="12.5"
                          MouseDoubleClick="EntriesGrid_OnMouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="*" MinWidth="100"/>
                        <DataGridTextColumn Header="系统名称" Binding="{Binding SystemName}" Width="120" MinWidth="88"/>
                        <DataGridTextColumn Header="级别" Binding="{Binding SystemLevelDisplay}" Width="56"/>
                        <DataGridTextColumn Header="分组" Binding="{Binding Group}" Width="90"/>
                        <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="120"/>
                        <DataGridTextColumn Header="密码" Binding="{Binding PasswordMask}" Width="88"/>
                        <DataGridTextColumn Header="网址" Binding="{Binding Url}" Width="2*" MinWidth="120"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Notes}" Width="2*" MinWidth="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
