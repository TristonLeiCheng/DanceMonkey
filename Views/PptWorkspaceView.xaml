<UserControl x:Class="DesktopAssistant.Views.PptWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部说明 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="PPT 工作台" FontSize="16" FontWeight="SemiBold" Foreground="#1F2330"/>
            <TextBlock Text="从笔记 / 文件 / 主题生成高端大气的 PPT。先选来源，再挑主题与风格，确认大纲后渲染为 .pptx。"
                       TextWrapping="Wrap" Foreground="#5A6172" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 三栏主体 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="240"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="320" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：来源选择 -->
            <Border Grid.Column="0" BorderBrush="#D8DEE9" BorderThickness="1" Background="White" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                    <StackPanel>
                        <TextBlock Text="来源" FontWeight="SemiBold" FontSize="13" Foreground="#1F2330"/>
                        <TextBlock Text="选择 PPT 的内容输入。" Foreground="#7A8194" FontSize="11" Margin="0,2,0,10"/>

                        <RadioButton x:Name="SourceMarkdownRadio"
                                     GroupName="PptSource"
                                     Content="Markdown / 纯文本"
                                     IsChecked="True"
                                     Checked="SourceRadio_OnChecked"
                                     Margin="0,4,0,4"/>
                        <TextBlock Text="直接粘贴笔记内容或纯文本。" Foreground="#7A8194" FontSize="11" Margin="22,0,0,8"/>

                        <RadioButton x:Name="SourceTopicRadio"
                                     GroupName="PptSource"
                                     Content="只给主题（让 AI 自由展开）"
                                     Checked="SourceRadio_OnChecked"
                                     Margin="0,4,0,4"/>
                        <TextBlock Text="只填一句主题，AI 自行展开。" Foreground="#7A8194" FontSize="11" Margin="22,0,0,8"/>

                        <RadioButton x:Name="SourcePdfRadio"
                                     GroupName="PptSource"
                                     Content="导入 PDF 文件"
                                     Checked="SourceRadio_OnChecked"
                                     Margin="0,4,0,4"/>
                        <RadioButton x:Name="SourceWordRadio"
                                     GroupName="PptSource"
                                     Content="导入 Word 文件（.docx / .doc）"
                                     Checked="SourceRadio_OnChecked"
                                     Margin="0,4,0,4"/>
                        <Grid x:Name="FilePickerRow" Margin="0,4,0,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FilePathBox" Grid.Column="0" Height="28" Padding="6,2" BorderBrush="#D8DEE9" IsReadOnly="True"/>
                            <Button x:Name="BrowseFileBtn" Grid.Column="1" Content="选择…" Height="28" MinWidth="68" Margin="6,0,0,0" Click="BrowseFileBtn_OnClick"/>
                        </Grid>
                        <TextBlock x:Name="OfficeAvailabilityHint"
                                   TextWrapping="Wrap"
                                   Foreground="#C25A00" FontSize="11"
                                   Margin="0,4,0,8"
                                   Visibility="Collapsed"/>

                        <Separator Margin="0,12,0,8"/>

                        <TextBlock Text="主题 / Topic（仅 Topic 模式必填）"
                                   Foreground="#5A6172" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="TopicBox" Height="28" Padding="6,2" BorderBrush="#D8DEE9"/>

                        <TextBlock Text="正文（Markdown 或纯文本）"
                                   Foreground="#5A6172" FontSize="11" Margin="0,10,0,4"/>
                        <TextBox x:Name="SourceBox"
                                 Height="220"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Padding="6"
                                 BorderBrush="#D8DEE9"/>

                        <Button x:Name="LoadFromNoteBtn"
                                Content="从当前笔记载入…"
                                Height="30"
                                Margin="0,10,0,0"
                                Click="LoadFromNoteBtn_OnClick"
                                ToolTip="从笔记目录选择一篇 .md 笔记作为来源"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 中间：大纲预览 -->
            <Border Grid.Column="2" BorderBrush="#D8DEE9" BorderThickness="1" Background="White" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="14,12,14,8">
                        <TextBlock Text="大纲预览" FontWeight="SemiBold" FontSize="13" Foreground="#1F2330" VerticalAlignment="Center"/>
                        <TextBlock x:Name="OutlineStatusText" Foreground="#7A8194" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,0,14,14">
                        <StackPanel x:Name="OutlinePanel">
                            <TextBlock Text="点击「生成大纲」后，这里会按章节展示页标题与要点，可直接编辑后再渲染。"
                                       Foreground="#7A8194" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 右侧：主题与参数 -->
            <Border Grid.Column="4" BorderBrush="#D8DEE9" BorderThickness="1" Background="White" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                    <StackPanel>
                        <TextBlock Text="主题" FontWeight="SemiBold" FontSize="13" Foreground="#1F2330"/>
                        <TextBlock Text="选择 PPT 的整体视觉风格。" Foreground="#7A8194" FontSize="11" Margin="0,2,0,10"/>

                        <ItemsControl x:Name="ThemeList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4" Padding="10" BorderThickness="1"
                                            BorderBrush="#D8DEE9" CornerRadius="3"
                                            Background="#FCFCFD">
                                        <StackPanel>
                                            <RadioButton GroupName="PptTheme"
                                                         Tag="{Binding Id}"
                                                         IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                         Checked="ThemeRadio_OnChecked">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Foreground="#1F2330" FontSize="12"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="#5A6172" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </RadioButton>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,14,0,10"/>

                        <TextBlock Text="生成参数" FontWeight="SemiBold" FontSize="13" Foreground="#1F2330"/>

                        <TextBlock Text="目标受众" Foreground="#5A6172" FontSize="11" Margin="0,8,0,4"/>
                        <TextBox x:Name="AudienceBox" Height="28" Padding="6,2" BorderBrush="#D8DEE9"
                                 ToolTip="例如：公司管理层、研发同事、客户"/>

                        <TextBlock Text="演示目的" Foreground="#5A6172" FontSize="11" Margin="0,8,0,4"/>
                        <TextBox x:Name="PurposeBox" Height="28" Padding="6,2" BorderBrush="#D8DEE9"
                                 ToolTip="例如：方案宣讲、技术分享、季度复盘"/>

                        <TextBlock Text="语气 / 风格" Foreground="#5A6172" FontSize="11" Margin="0,8,0,4"/>
                        <TextBox x:Name="ToneBox" Height="28" Padding="6,2" BorderBrush="#D8DEE9"
                                 ToolTip="例如：克制专业、热情活泼"/>

                        <TextBlock Text="目标页数（含封面/结尾）" Foreground="#5A6172" FontSize="11" Margin="0,8,0,4"/>
                        <TextBox x:Name="TargetSlidesBox" Height="28" Padding="6,2" BorderBrush="#D8DEE9"
                                 ToolTip="留空让 AI 自动决定"/>

                        <CheckBox x:Name="SpeakerNotesCheck"
                                  Content="生成演讲备注"
                                  IsChecked="True"
                                  Margin="0,12,0,0"
                                  ToolTip="为每张内容页生成演讲备注（写入 pptx notes slide，P3 接入）"/>

                        <CheckBox x:Name="LegacyPromptCheck"
                                  Content="使用旧版提示词（兼容回退）"
                                  Margin="0,6,0,0"
                                  ToolTip="勾选后改走 P1 旧 prompt + 旧 schema，便于回滚验证"/>

                        <TextBlock Text="附加约束（可选）" Foreground="#5A6172" FontSize="11" Margin="0,12,0,4"/>
                        <TextBox x:Name="ExtraInstructionsBox"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="6"
                                 BorderBrush="#D8DEE9"
                                 ToolTip="例如：不要提竞争对手 X；强调降本"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" BorderBrush="#D8DEE9" BorderThickness="0,1,0,0" Margin="0,12,0,0" Padding="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Foreground="#5A6172" FontSize="12" VerticalAlignment="Center"
                           Text="准备就绪。"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="GenerateOutlineBtn"
                            Content="生成大纲"
                            MinWidth="110" Height="34"
                            Click="GenerateOutlineBtn_OnClick"/>
                    <Button x:Name="RenderBtn"
                            Content="渲染为 PPTX…"
                            MinWidth="130" Height="34"
                            Margin="10,0,0,0"
                            IsEnabled="False"
                            Click="RenderBtn_OnClick"/>
                    <Button x:Name="OneShotBtn"
                            Content="一键生成"
                            MinWidth="110" Height="34"
                            Margin="10,0,0,0"
                            Click="OneShotBtn_OnClick"
                            ToolTip="跳过大纲预览，直接生成 .pptx"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
