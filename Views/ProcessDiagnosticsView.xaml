<UserControl x:Class="DesktopAssistant.Views.ProcessDiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4,0,4,20" MaxWidth="960">
            <!-- 页面标题 -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="进程诊断" Style="{StaticResource UiPageTitle}"/>
                <TextBlock Text="拖入 .exe / 快捷方式 或 选择运行中进程，实时分析进程树与网络连接" Style="{StaticResource UiPageSubtitle}"/>
            </StackPanel>

            <!-- 拖拽区域 + 进程选择器 -->
            <Border Style="{StaticResource UiCard}">
                <StackPanel>
                    <!-- 拖拽目标区域 -->
                    <Border x:Name="DropZone" AllowDrop="True" Drop="DropZone_OnDrop" DragOver="DropZone_OnDragOver" DragLeave="DropZone_OnDragLeave"
                            CornerRadius="12" BorderThickness="2" BorderBrush="#D0D5DD" Background="#FAFBFC"
                            Padding="30,24" Margin="0,0,0,14" Cursor="Hand" MouseLeftButtonUp="DropZone_OnClick">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#7C5CFC"/>
                                        <Setter Property="Background" Value="#F8F6FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📂" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="将 .exe 或快捷方式拖拽至此" HorizontalAlignment="Center"
                                       FontSize="14" FontWeight="Medium" Foreground="{StaticResource BrushTextPrimary}"/>
                            <TextBlock Text="或点击此区域从运行中进程列表选择" HorizontalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource BrushTextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 进程选择器弹出列表 -->
                    <Border x:Name="ProcessPickerPanel" Visibility="Collapsed" CornerRadius="8"
                            Background="{StaticResource BrushSurfaceMuted}" BorderBrush="{StaticResource BrushBorderSubtle}"
                            BorderThickness="1" Padding="10" Margin="0,0,0,10" MaxHeight="300">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBox x:Name="ProcessFilterBox" Style="{StaticResource UiTextBox}" FontSize="12.5"
                                         TextChanged="ProcessFilterBox_OnTextChanged"/>
                                <TextBlock x:Name="ProcessFilterPlaceholder" Text="🔍 搜索进程名…" FontSize="12" Foreground="{StaticResource BrushTextMuted}"
                                           IsHitTestVisible="False" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Width="22" Height="22" FontSize="10" Background="Transparent"
                                        BorderThickness="0" Cursor="Hand" Foreground="{StaticResource BrushTextMuted}"
                                        Click="CloseProcessPicker_OnClick"/>
                            </Grid>
                            <ListBox x:Name="ProcessList" MaxHeight="220" BorderThickness="0" Background="Transparent"
                                     SelectionChanged="ProcessList_OnSelectionChanged" FontSize="12.5">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2,3">
                                            <TextBlock Text="{Binding Display}" Foreground="{StaticResource BrushTextPrimary}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 当前监控目标 -->
            <Border x:Name="MonitorHeader" Style="{StaticResource UiCard}" Visibility="Collapsed">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock x:Name="TargetProcessName" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource BrushTextPrimary}"/>
                            <TextBlock x:Name="TargetProcessDetail" FontSize="12" Foreground="{StaticResource BrushTextSecondary}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="AskAiBtn" Content="🤖 AI 诊断" Style="{StaticResource UiBtnPrimary}" Padding="14,8"
                                Click="AskAiBtn_OnClick" Margin="0,0,8,0"/>
                        <Button x:Name="RefreshBtn" Content="🔄 刷新" Style="{StaticResource UiBtnSecondary}" Padding="14,8"
                                Click="RefreshBtn_OnClick" Margin="0,0,8,0"/>
                        <Button Content="✕ 停止" Style="{StaticResource UiBtnSecondary}" Padding="14,8"
                                Click="StopMonitor_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ETW 状态提示 -->
            <Border x:Name="EtwStatusBanner" Visibility="Collapsed" CornerRadius="8" Padding="12,8" Margin="0,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="EtwStatusIcon" Text="⚡" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="EtwStatusText" FontSize="12" VerticalAlignment="Center"
                               TextWrapping="Wrap" Foreground="{StaticResource BrushTextSecondary}"/>
                </StackPanel>
            </Border>

            <!-- 流量汇总卡片 -->
            <Border x:Name="TrafficSummaryCard" Style="{StaticResource UiCard}" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="📊 实时流量" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="8" Background="#F0FDF4" Padding="12,10" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⬆ 发送" FontSize="11" Foreground="#059669" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TrafficSentText" Text="0 B" FontSize="16" FontWeight="Bold"
                                           Foreground="#059669" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                <TextBlock x:Name="TrafficSentPkts" Text="0 包" FontSize="10.5"
                                           Foreground="#6EE7B7" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" CornerRadius="8" Background="#EFF6FF" Padding="12,10" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="⬇ 接收" FontSize="11" Foreground="#2563EB" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TrafficRecvText" Text="0 B" FontSize="16" FontWeight="Bold"
                                           Foreground="#2563EB" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                <TextBlock x:Name="TrafficRecvPkts" Text="0 包" FontSize="10.5"
                                           Foreground="#93C5FD" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" CornerRadius="8" Background="#FDF4FF" Padding="12,10" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="合计" FontSize="11" Foreground="#9333EA" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TrafficTotalText" Text="0 B" FontSize="16" FontWeight="Bold"
                                           Foreground="#9333EA" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                <TextBlock x:Name="TrafficConnCount" Text="0 连接" FontSize="10.5"
                                           Foreground="#D8B4FE" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" CornerRadius="8" Background="#FFF7ED" Padding="12,10">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="DNS" FontSize="11" Foreground="#EA580C" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="DnsCountText" Text="0" FontSize="16" FontWeight="Bold"
                                           Foreground="#EA580C" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                <TextBlock Text="次查询" FontSize="10.5" Foreground="#FDBA74" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 进程树 -->
            <Border x:Name="TreeCard" Style="{StaticResource UiCard}" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="进程树" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,10"/>
                    <Border Background="{StaticResource BrushSurfaceMuted}" CornerRadius="8" Padding="14,10" BorderThickness="1"
                            BorderBrush="{StaticResource BrushBorderSubtle}">
                        <TextBlock x:Name="TreeText" FontFamily="Cascadia Code, Consolas, monospace" FontSize="12"
                                   Foreground="{StaticResource BrushTextPrimary}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 网络连接表 -->
            <Border x:Name="ConnectionsCard" Style="{StaticResource UiCard}" Visibility="Collapsed" Margin="0,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="网络连接" Style="{StaticResource UiSectionTitle}" Margin="0"/>
                        <TextBlock x:Name="ConnectionCountText" FontSize="12" Foreground="{StaticResource BrushTextMuted}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <CheckBox x:Name="AutoRefreshCheck" Content="每 3 秒自动刷新" VerticalAlignment="Center"
                                  Margin="20,0,0,0" FontSize="12" Foreground="{StaticResource BrushTextSecondary}"
                                  IsChecked="True" Checked="AutoRefreshCheck_Changed" Unchecked="AutoRefreshCheck_Changed"/>
                    </StackPanel>
                    <DataGrid x:Name="ConnectionGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" Background="Transparent" RowBackground="Transparent"
                              AlternatingRowBackground="#F9FAFB" FontSize="12"
                              CanUserSortColumns="True" CanUserReorderColumns="False"
                              ColumnHeaderHeight="32" RowHeight="28"
                              HorizontalGridLinesBrush="#F0F0F0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource BrushSurfaceMuted}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
                                <Setter Property="FontSize" Value="11.5"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PID" Binding="{Binding OwningPid}" Width="60"/>
                            <DataGridTextColumn Header="进程" Binding="{Binding ProcessName}" Width="100"/>
                            <DataGridTextColumn Header="协议" Binding="{Binding Protocol}" Width="50"/>
                            <DataGridTextColumn Header="本地地址" Binding="{Binding LocalDisplay}" Width="150"/>
                            <DataGridTextColumn Header="远程地址" Binding="{Binding RemoteDisplay}" Width="*"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="90"/>
                            <DataGridTextColumn Header="⬆发送" Binding="{Binding SentDisplay}" Width="80"/>
                            <DataGridTextColumn Header="⬇接收" Binding="{Binding RecvDisplay}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="NoConnectionsText" Text="（当前无活跃网络连接）" Visibility="Collapsed"
                               Foreground="{StaticResource BrushTextMuted}" FontSize="12.5" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- AI 诊断结果 -->
            <Border x:Name="AiResultCard" Style="{StaticResource UiCard}" Visibility="Collapsed" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="🤖 AI 诊断结果" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,10"/>
                    <Border Background="{StaticResource BrushSurfaceMuted}" CornerRadius="8" Padding="14,10"
                            BorderThickness="1" BorderBrush="{StaticResource BrushBorderSubtle}">
                        <TextBlock x:Name="AiResultText" FontSize="12.5" TextWrapping="Wrap"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- DNS 查询记录 -->
            <Border x:Name="DnsCard" Style="{StaticResource UiCard}" Visibility="Collapsed" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="🌐 DNS 查询记录" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,10"/>
                    <DataGrid x:Name="DnsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" Background="Transparent" RowBackground="Transparent"
                              AlternatingRowBackground="#F9FAFB" FontSize="11.5"
                              CanUserSortColumns="True" CanUserReorderColumns="False"
                              MaxHeight="200"
                              ColumnHeaderHeight="28" RowHeight="24"
                              HorizontalGridLinesBrush="#F0F0F0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource BrushSurfaceMuted}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="6,3"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="90"/>
                            <DataGridTextColumn Header="域名" Binding="{Binding QueryName}" Width="*"/>
                            <DataGridTextColumn Header="结果" Binding="{Binding Results}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="NoDnsText" Text="（暂无 DNS 查询记录）" Visibility="Collapsed"
                               Foreground="{StaticResource BrushTextMuted}" FontSize="12" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
