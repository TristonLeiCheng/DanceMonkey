<Window x:Class="DesktopAssistant.Views.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入" Height="Auto" Width="420" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" SizeToContent="Height"
        Background="{StaticResource BrushPageBg}">
    <Border Padding="20" Background="{StaticResource BrushPageBg}">
        <StackPanel>
            <TextBlock x:Name="LabelText" Margin="0,0,0,8" FontSize="13" Foreground="{StaticResource BrushTextSecondary}"/>
            <TextBox x:Name="InputBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,16"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="确定" Style="{StaticResource UiBtnPrimary}" MinWidth="90" Margin="0,0,8,0" IsDefault="True" Click="Ok_OnClick"/>
                <Button Content="取消" Style="{StaticResource UiBtnSecondary}" MinWidth="90" IsCancel="True" Click="Cancel_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
