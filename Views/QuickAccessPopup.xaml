<Window x:Class="DesktopAssistant.Views.QuickAccessPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="820" Height="500"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Deactivated="OnDeactivated"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <!-- Tab pill style -->
        <Style x:Key="PopupTabBtn" TargetType="RadioButton">
            <Setter Property="GroupName" Value="PopupTab"/>
            <Setter Property="Foreground" Value="#B0FFFFFF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#28FFFFFF"/>
                                <Setter Property="Foreground" Value="#DDFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tile button style -->
        <Style x:Key="PopupTileBtn" TargetType="Button">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="#F2FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#24FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Width" Value="176"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Glow"
                                    Margin="2,4,2,0"
                                    CornerRadius="16"
                                    Background="#55FFFFFF"
                                    Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.22" Color="#7AA8FF"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="Bd"
                                    Margin="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18" Color="#000000"/>
                                </Border.Effect>
                                <Grid>
                                    <Border x:Name="AccentStrip"
                                            Width="3"
                                            HorizontalAlignment="Left"
                                            Margin="-10,2,0,2"
                                            CornerRadius="2"
                                            Background="#A8FFFFFF"
                                            Opacity="0.42"/>
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Margin" Value="0,-2,0,2"/>
                                <Setter TargetName="Bd" Property="Background" Value="#2FFFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#62FFFFFF"/>
                                <Setter TargetName="Glow" Property="Opacity" Value="0.42"/>
                                <Setter TargetName="AccentStrip" Property="Opacity" Value="0.92"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="22" ShadowDepth="6" Opacity="0.26" Color="#000000"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Margin" Value="0,0,0,0"/>
                                <Setter TargetName="Bd" Property="Background" Value="#42FFFFFF"/>
                                <Setter TargetName="Glow" Property="Opacity" Value="0.18"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer card -->
    <Border CornerRadius="20" Margin="14"
            BorderBrush="#34FFFFFF" BorderThickness="1">
        <Border.Background>
            <SolidColorBrush x:Name="CardBg" Color="#1A3A5C" Opacity="0.96"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="46" ShadowDepth="12" Opacity="0.48" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Search -->
                <RowDefinition Height="Auto"/>  <!-- Tab strip -->
                <RowDefinition Height="*"/>     <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <Grid Grid.Row="0" Margin="18,14,14,0">
                <TextBlock Text="⚡ 快速访问" FontSize="14" FontWeight="SemiBold"
                           Foreground="#E0FFFFFF" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right"
                        FontSize="11" Foreground="#70FFFFFF"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Width="28" Height="28"
                        Click="BtnClose_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#30E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Row 1: Search box -->
            <Border Grid.Row="1" Margin="12,10,12,0"
                    Background="#18FFFFFF" BorderBrush="#26FFFFFF" BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="12" Margin="10,0,6,0"
                                   VerticalAlignment="Center" Foreground="#70FFFFFF"/>
                        <TextBox x:Name="SearchBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#E0FFFFFF" CaretBrush="#E0FFFFFF"
                                 Padding="0,7" FontSize="12.5" MinWidth="200"
                                 TextChanged="SearchBox_TextChanged">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="9"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                    <TextBlock x:Name="SearchPlaceholder"
                               Text="搜索快捷方式..." FontSize="12.5"
                               Foreground="#50FFFFFF" VerticalAlignment="Center"
                               Margin="32,0,0,0" IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Row 2: Tab strip -->
            <Border Grid.Row="2" Margin="12,8,12,0"
                    Background="#16FFFFFF" CornerRadius="12" Padding="5,4">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TabStrip" Orientation="Horizontal"/>
                </ScrollViewer>
            </Border>

            <!-- Row 3: Scrollable content -->
            <ScrollViewer Grid.Row="3" Margin="12,8,12,12"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <WrapPanel x:Name="ContentPanel"
                           Orientation="Horizontal"
                           Margin="0,0,0,4"/>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>
