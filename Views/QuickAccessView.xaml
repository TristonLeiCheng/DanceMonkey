<UserControl x:Class="DesktopAssistant.Views.QuickAccessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>

        <!-- ═══ 导航 Tab 标签（RadioButton pill 样式） ═══ -->
        <Style x:Key="NavTabRadio" TargetType="RadioButton">
            <Setter Property="GroupName" Value="QATab"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushSurfaceHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushAccentMuted}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ 快捷方式磁贴样式 ═══ -->
        <Style x:Key="TileButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Glow"
                                    Margin="2,4,2,0"
                                    CornerRadius="18"
                                    Background="{StaticResource BrushAccentGradient}"
                                    Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="22" ShadowDepth="8" Opacity="0.20" Color="#4F6EF7"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="Bd"
                                    Margin="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16"
                                    Padding="{TemplateBinding Padding}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#2D2A26"/>
                                </Border.Effect>
                                <Grid>
                                    <Border x:Name="AccentStrip"
                                            Width="3"
                                            HorizontalAlignment="Left"
                                            Margin="-14,2,0,2"
                                            CornerRadius="2"
                                            Background="{StaticResource BrushAccentGradient}"
                                            Opacity="0.45"/>
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Margin" Value="0,-2,0,2"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                <Setter TargetName="Glow" Property="Opacity" Value="0.18"/>
                                <Setter TargetName="AccentStrip" Property="Opacity" Value="0.95"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.14" Color="#2D2A26"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Margin" Value="0,0,0,0"/>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushAccentMuted}"/>
                                <Setter TargetName="Glow" Property="Opacity" Value="0.08"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="#2D2A26"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <DockPanel>

        <!-- ═══ 顶部工具栏 ═══ -->
        <Border DockPanel.Dock="Top" Background="Transparent" Padding="2,0,2,0">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 标题 -->
                <TextBlock Grid.Column="0" Text="{DynamicResource QuickAccess.Title}"
                           Style="{StaticResource UiPageTitle}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- 搜索框 -->
                <Border Grid.Column="1" Background="{StaticResource BrushSurface}"
                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                        CornerRadius="8" VerticalAlignment="Center">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="13" Margin="10,0,6,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBox x:Name="SearchBox" Style="{StaticResource UiTextBox}"
                                     BorderThickness="0" Background="Transparent"
                                     Padding="0,7" MinWidth="220" FontSize="13"
                                     TextChanged="Search_TextChanged"/>
                        </StackPanel>
                        <TextBlock x:Name="SearchPlaceholder"
                                   Text="{DynamicResource QuickAccess.SearchHint}"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="32,0,0,0" IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- 排序 + 操作按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Margin="10,0,0,0" VerticalAlignment="Center">
                    <Border Background="{StaticResource BrushSurfaceMuted}"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="4,2" Margin="0,0,6,0">
                        <ComboBox x:Name="SortCombo" Style="{StaticResource UiComboBox}"
                                  BorderThickness="0" Background="Transparent" MinWidth="110"
                                  SelectionChanged="Sort_Changed">
                            <ComboBoxItem Tag="freq"   Content="{DynamicResource QuickAccess.SortFreq}"   IsSelected="True"/>
                            <ComboBoxItem Tag="name"   Content="{DynamicResource QuickAccess.SortName}"/>
                            <ComboBoxItem Tag="recent" Content="{DynamicResource QuickAccess.SortRecent}"/>
                        </ComboBox>
                    </Border>
                    <Button Content="{DynamicResource QuickAccess.AddLink}"
                            Style="{StaticResource UiBtnPrimary}"
                            Padding="14,6" Margin="0,0,6,0" Click="AddLink_OnClick"/>
                    <Button Content="{DynamicResource QuickAccess.Refresh}"
                            Style="{StaticResource UiBtnSecondary}"
                            Padding="14,6" Click="RefreshLinks_OnClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Tab 导航栏 ═══ -->
        <Border DockPanel.Dock="Top" Background="Transparent" Padding="0,0,0,10">
            <Border Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="1"
                    CornerRadius="10" Padding="4,3">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TabStrip" Orientation="Horizontal"/>
                </ScrollViewer>
            </Border>
        </Border>

        <!-- ═══ 内容区域 ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="0">
            <StackPanel x:Name="ContentPanel" Margin="2,0,2,24"/>
        </ScrollViewer>

    </DockPanel>
</UserControl>
