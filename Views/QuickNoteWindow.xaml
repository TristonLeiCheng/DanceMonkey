<Window x:Class="DesktopAssistant.Views.QuickNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速笔录" Height="420" Width="520" MinHeight="280" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushPageBg}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="内容将保存到笔记库 Inbox 目录" Style="{StaticResource UiHint}" Margin="0,0,0,10" TextWrapping="Wrap"/>
        <TextBox x:Name="BodyBox" Grid.Row="1" Style="{StaticResource UiTextBox}" AcceptsReturn="True"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="13.5"
                 Text=""/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="保存并关闭" Style="{StaticResource UiBtnSuccess}" MinWidth="110" Margin="0,0,8,0" Click="Save_OnClick"/>
            <Button Content="取消" Style="{StaticResource UiBtnSecondary}" MinWidth="90" IsCancel="True" Click="Cancel_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
