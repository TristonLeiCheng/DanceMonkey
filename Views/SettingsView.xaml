<UserControl x:Class="DesktopAssistant.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DesktopAssistant.Views"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                 Background="Transparent"
                                 BorderBrush="{StaticResource BrushBorderSubtle}"
                                 BorderThickness="1"
                                 CornerRadius="9"
                                 Padding="{TemplateBinding Padding}"
                                 SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushSurfaceMuted}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushAccentGradient}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextOnAccent}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsTabItem}"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                             <Border Grid.Row="0"
                                     Background="{StaticResource BrushSurface}"
                                     BorderBrush="{StaticResource BrushBorderSubtle}"
                                     BorderThickness="1"
                                     CornerRadius="12"
                                     Padding="7"
                                     Margin="0,0,0,8">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              Focusable="False"
                                              ClipToBounds="True"
                                              CanContentScroll="False">
                                    <ItemsPresenter KeyboardNavigation.TabIndex="1"/>
                                </ScrollViewer>
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsTabScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="0,10,6,0"/>
        </Style>

        <Style x:Key="SettingsCard" TargetType="Border" BasedOn="{StaticResource UiCard}">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="4,0,4,10" MaxWidth="1080">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource Settings.Title}" Style="{StaticResource UiPageTitle}"/>
            <TextBlock Text="{DynamicResource Settings.Subtitle}" Style="{StaticResource UiPageSubtitle}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource UiCard}" Padding="12,10" Margin="0,0,0,10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button x:Name="TestBtn"
                            Content="{DynamicResource Settings.TestConnection}"
                            Style="{StaticResource UiBtnSecondary}"
                            MinWidth="110"
                            Margin="0,0,8,0"
                            Click="TestBtn_OnClick"/>
                    <Button x:Name="SaveBtn"
                            Content="{DynamicResource Settings.SaveAll}"
                            Style="{StaticResource UiBtnSuccess}"
                            MinWidth="130"
                            Click="SaveBtn_OnClick"/>
                </StackPanel>
                <TextBlock Text="{DynamicResource Settings.SaveHint}"
                           Style="{StaticResource UiHint}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <TabControl x:Name="SettingsTabs" Grid.Row="2" Style="{StaticResource SettingsTabControl}">
            <TabItem Header="AI 连接">
                <ScrollViewer Style="{StaticResource SettingsTabScrollViewer}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.Connection}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,6"/>

                                <TextBlock Text="{DynamicResource Settings.ApiProvider}" Style="{StaticResource UiFieldLabel}"/>
                                <ComboBox x:Name="Provider"
                                          Style="{StaticResource UiComboBox}"
                                          Margin="0,0,0,8"
                                          SelectionChanged="Provider_OnSelectionChanged"/>

                                <TextBlock Text="{DynamicResource Settings.ApiEndpoint}" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="Endpoint" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                <TextBlock Style="{StaticResource UiHint}" Margin="0,0,0,8" TextWrapping="Wrap"
                                           Text="{DynamicResource Settings.ApiEndpointHint}"/>

                                <TextBlock Text="{DynamicResource Settings.ApiKey}" Style="{StaticResource UiFieldLabel}"/>
                                <PasswordBox x:Name="ApiKeyBox" Style="{StaticResource UiPasswordBox}" Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Settings.ApiKeyHint}" Style="{StaticResource UiHint}" Margin="0,0,0,8"/>

                                <TextBlock Text="{DynamicResource Settings.ModelName}" Style="{StaticResource UiFieldLabel}"/>
                                <ComboBox x:Name="ModelCombo"
                                          Style="{StaticResource UiComboBox}"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          Margin="0,0,0,8"/>

                                <Border Background="{StaticResource BrushSurfaceMuted}"
                                        BorderBrush="{StaticResource BrushBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,10"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="可切换模型列表" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBlock Text="添加常用模型后，可在 AI 聊天页直接切换；CLI 默认使用当前模型，也可用 --model 传入这里的名称或模型 ID。"
                                                   Style="{StaticResource UiHint}"
                                                   Margin="0,0,0,8"
                                                   TextWrapping="Wrap"/>
                                        <ListView x:Name="ModelProfilesList"
                                                  Height="128"
                                                  Margin="0,0,0,8"
                                                  BorderBrush="{StaticResource BrushBorderSubtle}"
                                                  BorderThickness="1"
                                                  Background="{StaticResource BrushSurface}">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="显示名称" Width="180" DisplayMemberBinding="{Binding Name}"/>
                                                    <GridViewColumn Header="模型 ID" Width="420" DisplayMemberBinding="{Binding Model}"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>

                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="显示名称" Style="{StaticResource UiFieldLabel}"/>
                                                <TextBox x:Name="ModelProfileNameBox" Style="{StaticResource UiTextBox}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="模型 ID" Style="{StaticResource UiFieldLabel}"/>
                                                <TextBox x:Name="ModelProfileValueBox" Style="{StaticResource UiTextBox}"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="添加 / 更新模型"
                                                    Style="{StaticResource UiBtnPrimary}"
                                                    MinWidth="118"
                                                    Margin="0,0,8,0"
                                                    Click="AddModelProfile_OnClick"/>
                                            <Button Content="设为当前"
                                                    Style="{StaticResource UiBtnSecondary}"
                                                    MinWidth="88"
                                                    Margin="0,0,8,0"
                                                    Click="UseSelectedModelProfile_OnClick"/>
                                            <Button Content="{DynamicResource Settings.RemoveSelected}"
                                                    Style="{StaticResource UiBtnSecondary}"
                                                    MinWidth="90"
                                                    Click="RemoveModelProfile_OnClick"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{DynamicResource Settings.ConnectionHint}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="网络代理">
                <ScrollViewer Style="{StaticResource SettingsTabScrollViewer}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="强制代理（防组策略回刷）" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="启用后会定时重写系统代理设置。适合在访问外网时临时覆盖公司 PAC 策略。"
                                           Style="{StaticResource UiHint}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <CheckBox x:Name="ProxyForceEnabledCheck"
                                          Content="启用强制代理"
                                          Style="{StaticResource SettingsCheckBox}"/>

                                <TextBlock Text="模式" Style="{StaticResource UiFieldLabel}"/>
                                <ComboBox x:Name="ProxyModeCombo"
                                          Style="{StaticResource UiComboBox}"
                                          Margin="0,0,0,8"
                                          SelectionChanged="ProxyModeCombo_OnSelectionChanged">
                                    <ComboBoxItem Tag="manual" Content="手动代理（地址 + 端口）"/>
                                    <ComboBoxItem Tag="pac" Content="PAC 脚本地址"/>
                                </ComboBox>

                                <TextBlock Text="PAC 地址（PAC 模式）" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="ProxyPacUrlBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,8"/>

                                <TextBlock Text="上海 PAC 地址（托盘快捷）" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="ProxyPacShanghaiBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,6"/>
                                <TextBlock Text="北京 PAC 地址（托盘快捷）" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="ProxyPacBeijingBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,8"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="代理地址（手动模式）" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="ProxyServerBox" Style="{StaticResource UiTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="端口" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="ProxyPortBox" Style="{StaticResource UiTextBox}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="例外地址（可选）" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="ProxyBypassBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                <TextBlock Text="示例：&lt;local&gt;;*.corp.local" Style="{StaticResource UiHint}" Margin="0,0,0,8"/>

                                <TextBlock Text="强制刷新间隔（分钟）" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="ProxyRefreshMinutesBox" Style="{StaticResource UiTextBox}" Width="90" HorizontalAlignment="Left" Margin="0,0,0,2"/>
                                <TextBlock Text="建议 1~5 分钟。组策略每次改写后会在下个周期重新覆盖回你设置的代理。"
                                           Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="聊天与快捷键">
                <ScrollViewer Style="{StaticResource SettingsTabScrollViewer}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.GlobalChat}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{DynamicResource Settings.GlobalChatHint}" Style="{StaticResource UiHint}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Settings.GlobalHotkey}" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="GlobalChatHotkeyBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                        <TextBlock Text="{DynamicResource Settings.GlobalHotkeyHint}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{DynamicResource Settings.QuickScreenshotHotkey}" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="QuickScreenshotHotkeyBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                        <TextBlock Text="{DynamicResource Settings.QuickScreenshotHotkeyHint}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{DynamicResource Settings.RegionScreenshotHotkey}" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="RegionScreenshotHotkeyBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                        <TextBlock Text="{DynamicResource Settings.RegionScreenshotHotkeyHint}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{DynamicResource Settings.SystemPrompt}" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="GlobalChatPromptBox"
                                         Style="{StaticResource UiTextBox}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="92"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Settings.SystemPromptHint}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="界面与启动">
                <ScrollViewer Style="{StaticResource SettingsTabScrollViewer}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.UI}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,8"/>

                                <TextBlock Text="{DynamicResource Settings.Language}" Style="{StaticResource UiFieldLabel}"/>
                                <ComboBox x:Name="LanguageCombo" Style="{StaticResource UiComboBox}" Margin="0,0,0,8"/>

                                <CheckBox x:Name="FloatingIconCheck"
                                          Content="{DynamicResource Settings.FloatingIcon}"
                                          Style="{StaticResource SettingsCheckBox}"/>
                                <TextBlock Text="{DynamicResource Settings.FloatingIconHint}" Style="{StaticResource UiHint}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <CheckBox x:Name="StartWithWindowsCheck"
                                          Content="{DynamicResource Settings.StartWithWindows}"
                                          Style="{StaticResource SettingsCheckBox}"/>

                                <CheckBox x:Name="ClipboardHistoryCheck"
                                          Content="{DynamicResource Settings.ClipboardHistory}"
                                          Style="{StaticResource SettingsCheckBox}"/>

                                <CheckBox x:Name="TaskbarResourceMonitorCheck"
                                          Content="任务栏显示资源监控（CPU/内存/磁盘/网络）"
                                          Style="{StaticResource SettingsCheckBox}"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="资源监控刷新间隔（秒）"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               Margin="0,0,8,0"/>
                                    <TextBox x:Name="TaskbarResourceIntervalBox"
                                             Style="{StaticResource UiTextBox}"
                                             Width="64"/>
                                </StackPanel>
                                <TextBlock Text="{DynamicResource Settings.ClipboardHistoryHint}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="剪贴板历史" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,6"/>
                                <ListBox x:Name="ClipboardHistoryList"
                                         MinHeight="140"
                                         MaxHeight="260"
                                         Margin="0,0,0,8"
                                         FontSize="12.5"
                                         Foreground="{StaticResource BrushTextPrimary}"
                                         BorderBrush="{StaticResource BrushBorderSubtle}"
                                         BorderThickness="1"
                                         Background="{StaticResource BrushSurfaceMuted}"
                                         MouseDoubleClick="ClipboardHistoryList_OnMouseDoubleClick"/>
                                <Button Content="{DynamicResource Settings.ClearClipboard}"
                                        Style="{StaticResource UiBtnSecondary}"
                                        HorizontalAlignment="Left"
                                        Padding="12,6"
                                        Click="ClearClipboardHistory_OnClick"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="NotesQuickAccessTab" Header="笔记与快捷入口">
                <ScrollViewer Style="{StaticResource SettingsTabScrollViewer}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.NotesDir}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,6"/>
                                <TextBox x:Name="NotesRootPathBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,4"/>
                                <TextBlock Text="{DynamicResource Settings.NotesDirHint}" Style="{StaticResource UiHint}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <CheckBox x:Name="NotesRestoreStickiesCheck"
                                          Content="{DynamicResource Settings.RestoreStickies}"
                                          Style="{StaticResource SettingsCheckBox}"/>
                                <Button Content="{DynamicResource Settings.BrowseFolder}"
                                        Style="{StaticResource UiBtnSecondary}"
                                        HorizontalAlignment="Left"
                                        Padding="12,6"
                                        Click="BrowseNotesRoot_OnClick"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.QuickAccess}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,6"/>
                                <ListView x:Name="QuickLinksList"
                                          Height="140"
                                          Margin="0,0,0,8"
                                          BorderBrush="{StaticResource BrushBorderSubtle}"
                                          BorderThickness="1"
                                          Background="{StaticResource BrushSurfaceMuted}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="{DynamicResource Settings.QuickAccessName}" Width="130" DisplayMemberBinding="{Binding Name}"/>
                                            <GridViewColumn Header="{DynamicResource Settings.QuickAccessType}" Width="90" DisplayMemberBinding="{Binding Category}"/>
                                            <GridViewColumn Header="{DynamicResource Settings.QuickAccessPath}" Width="520" DisplayMemberBinding="{Binding Path}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2.2*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Settings.QuickAccessName}" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="QuickLinkNameBox" Style="{StaticResource UiTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{DynamicResource Settings.QuickAccessType}" Style="{StaticResource UiFieldLabel}"/>
                                        <ComboBox x:Name="QuickLinkCategoryCombo" Style="{StaticResource UiComboBox}">
                                            <ComboBoxItem Tag="local" Content="本地" IsSelected="True"/>
                                            <ComboBoxItem Tag="network" Content="网络"/>
                                            <ComboBoxItem Tag="sharepoint" Content="SharePoint"/>
                                            <ComboBoxItem Tag="onedrive" Content="OneDrive"/>
                                            <ComboBoxItem Tag="web" Content="Web"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{DynamicResource Settings.QuickAccessPath}" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="QuickLinkPathBox" Style="{StaticResource UiTextBox}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{DynamicResource Settings.Add}" Style="{StaticResource UiBtnPrimary}" MinWidth="80" Margin="0,0,8,0" Click="AddQuickLink_OnClick"/>
                                    <Button Content="{DynamicResource Settings.RemoveSelected}" Style="{StaticResource UiBtnSecondary}" MinWidth="90" Margin="0,0,8,0" Click="RemoveQuickLink_OnClick"/>
                                    <Button Content="{DynamicResource Settings.OpenInExplorer}" Style="{StaticResource UiBtnSecondary}" MinWidth="136" Click="OpenQuickLink_OnClick"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.PromptSnippets}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{DynamicResource Settings.PromptSnippetsHint}" Style="{StaticResource UiHint}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <ListView x:Name="PromptSnippetsList"
                                          Height="140"
                                          Margin="0,0,0,8"
                                          BorderBrush="{StaticResource BrushBorderSubtle}"
                                          BorderThickness="1"
                                          Background="{StaticResource BrushSurfaceMuted}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="{DynamicResource Settings.SnippetTitle}" Width="160" DisplayMemberBinding="{Binding Title}"/>
                                            <GridViewColumn Header="{DynamicResource Settings.SnippetSystemPrompt}" Width="580" DisplayMemberBinding="{Binding Preview}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="2.4*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Settings.SnippetTitle}" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="PromptSnippetTitleBox" Style="{StaticResource UiTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{DynamicResource Settings.SnippetSystemPrompt}" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="PromptSnippetBodyBox"
                                                 Style="{StaticResource UiTextBox}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 MinHeight="64"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{DynamicResource Settings.AddSnippet}" Style="{StaticResource UiBtnPrimary}" MinWidth="90" Margin="0,0,8,0" Click="AddPromptSnippet_OnClick"/>
                                    <Button Content="{DynamicResource Settings.RemoveSelected}" Style="{StaticResource UiBtnSecondary}" MinWidth="90" Click="RemovePromptSnippet_OnClick"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="FolderSyncTab" Header="文件夹同步">
                <ScrollViewer Style="{StaticResource SettingsTabScrollViewer}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="文件夹同步" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="用于本地文件夹与企业共享盘/局域网盘之间同步。主从单向会从主文件夹复制到从文件夹；完全同步会按较新文件互相复制，冲突时保留冲突副本。"
                                           Style="{StaticResource UiHint}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                <ListView x:Name="FolderSyncProfilesList"
                                          Height="128"
                                          Margin="0,0,0,8"
                                          SelectionChanged="FolderSyncProfilesList_OnSelectionChanged"
                                          BorderBrush="{StaticResource BrushBorderSubtle}"
                                          BorderThickness="1"
                                          Background="{StaticResource BrushSurfaceMuted}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="名称" Width="120" DisplayMemberBinding="{Binding Name}"/>
                                            <GridViewColumn Header="模式" Width="90" DisplayMemberBinding="{Binding ModeDisplayName}"/>
                                            <GridViewColumn Header="主文件夹" Width="260" DisplayMemberBinding="{Binding MasterPath}"/>
                                            <GridViewColumn Header="从文件夹" Width="260" DisplayMemberBinding="{Binding SlavePath}"/>
                                            <GridViewColumn Header="状态" Width="190" DisplayMemberBinding="{Binding LastStatus}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="1.2*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="同步名称" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="SyncNameBox" Style="{StaticResource UiTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="同步模式" Style="{StaticResource UiFieldLabel}"/>
                                        <ComboBox x:Name="SyncModeCombo" Style="{StaticResource UiComboBox}">
                                            <ComboBoxItem Tag="masterToSlave" Content="主从单向" IsSelected="True"/>
                                            <ComboBoxItem Tag="twoWay" Content="完全同步"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <CheckBox x:Name="SyncEnabledCheck" Content="启用" IsChecked="True"
                                                  Style="{StaticResource SettingsCheckBox}" Margin="0,0,12,2"/>
                                        <CheckBox x:Name="SyncAutoEnabledCheck" Content="自动同步"
                                                  Style="{StaticResource SettingsCheckBox}" Margin="0,0,12,2"/>
                                        <CheckBox x:Name="SyncDeleteExtraCheck" Content="单向删除从端多余文件"
                                                  Style="{StaticResource SettingsCheckBox}" Margin="0,0,0,2"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="主文件夹（本地电脑常用文件夹）" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="SyncMasterPathBox" Style="{StaticResource UiTextBox}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{DynamicResource Settings.BrowseFolder}"
                                            Style="{StaticResource UiBtnSecondary}" Padding="12,6"
                                            Margin="8,20,0,0" Click="BrowseSyncMaster_OnClick"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="从文件夹（部门共享盘/局域网盘）" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="SyncSlavePathBox" Style="{StaticResource UiTextBox}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{DynamicResource Settings.BrowseFolder}"
                                            Style="{StaticResource UiBtnSecondary}" Padding="12,6"
                                            Margin="8,20,0,0" Click="BrowseSyncSlave_OnClick"/>
                                </Grid>

                                <TextBlock Text="排除规则（分号分隔，支持 * 和 ?）" Style="{StaticResource UiFieldLabel}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SyncExcludeBox" Style="{StaticResource UiTextBox}"
                                             Text="*.tmp;~$*;.DS_Store;Thumbs.db"/>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="自动同步间隔（分钟）" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="SyncAutoIntervalBox" Style="{StaticResource UiTextBox}" Text="30"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="回收保留天数" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="SyncTrashRetentionBox" Style="{StaticResource UiTextBox}" Text="30"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="完全同步冲突策略" Style="{StaticResource UiFieldLabel}"/>
                                        <ComboBox x:Name="SyncConflictPolicyCombo" Style="{StaticResource UiComboBox}">
                                            <ComboBoxItem Tag="keepConflictCopy" Content="保留冲突副本（推荐）" IsSelected="True"/>
                                            <ComboBoxItem Tag="preferMaster" Content="主文件夹版本覆盖从文件夹"/>
                                            <ComboBoxItem Tag="preferSlave" Content="从文件夹版本覆盖主文件夹"/>
                                            <ComboBoxItem Tag="skip" Content="跳过冲突文件"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="仅在完全同步中主从两端都修改同一文件时生效。推荐保留冲突副本，避免误覆盖部门共享盘文件。"
                                               Style="{StaticResource UiHint}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Bottom"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="添加/更新任务" Style="{StaticResource UiBtnPrimary}" MinWidth="108" Margin="0,0,8,0" Click="AddOrUpdateSyncProfile_OnClick"/>
                                    <Button Content="{DynamicResource Settings.RemoveSelected}" Style="{StaticResource UiBtnSecondary}" MinWidth="90" Margin="0,0,8,0" Click="RemoveSyncProfile_OnClick"/>
                                    <Button Content="预览同步" Style="{StaticResource UiBtnSecondary}" MinWidth="90" Margin="0,0,8,0" Click="PreviewSyncProfile_OnClick"/>
                                    <Button Content="立即同步" Style="{StaticResource UiBtnSuccess}" MinWidth="90" Margin="0,0,8,0" Click="RunSyncProfile_OnClick"/>
                                    <Button Content="刷新日志" Style="{StaticResource UiBtnSecondary}" MinWidth="90" Margin="0,0,8,0" Click="RefreshSyncLog_OnClick"/>
                                    <Button Content="打开日志" Style="{StaticResource UiBtnSecondary}" MinWidth="90" Click="OpenSyncLog_OnClick"/>
                                </StackPanel>
                                <TextBlock x:Name="FolderSyncStatusText" Style="{StaticResource UiHint}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <ListView x:Name="FolderSyncPreviewList"
                                          Height="190"
                                          Margin="0,8,0,0"
                                          Visibility="Collapsed"
                                          BorderBrush="{StaticResource BrushBorderSubtle}"
                                          BorderThickness="1"
                                          Background="{StaticResource BrushSurfaceMuted}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="操作" Width="120" DisplayMemberBinding="{Binding Operation}"/>
                                            <GridViewColumn Header="标记" Width="56" DisplayMemberBinding="{Binding ConflictDisplay}"/>
                                            <GridViewColumn Header="文件" Width="280" DisplayMemberBinding="{Binding RelativePath}"/>
                                            <GridViewColumn Header="大小" Width="82" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                            <GridViewColumn Header="原因" Width="360" DisplayMemberBinding="{Binding Reason}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <TextBox x:Name="FolderSyncLogBox"
                                         Height="120"
                                         Margin="0,8,0,0"
                                         Visibility="Collapsed"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Style="{StaticResource UiTextBox}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="语音与会议">
                <ScrollViewer Style="{StaticResource SettingsTabScrollViewer}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.MeetingAssistant}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,8"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource Settings.TranscriptionLang}" Style="{StaticResource UiFieldLabel}"/>
                                        <ComboBox x:Name="MeetingLanguageCombo" Style="{StaticResource UiComboBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{DynamicResource Settings.AudioSource}" Style="{StaticResource UiFieldLabel}"/>
                                        <ComboBox x:Name="MeetingAudioSourceCombo" Style="{StaticResource UiComboBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{DynamicResource Settings.SegmentSeconds}" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="MeetingSegmentSecondsBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{DynamicResource Settings.SegmentHint}" Style="{StaticResource UiHint}" Margin="0,0,0,8"/>
                                <CheckBox x:Name="MeetingAutoSummaryCheck"
                                          Content="{DynamicResource Settings.AutoSummary}"
                                          Style="{StaticResource SettingsCheckBox}"/>
                                <TextBlock Text="{DynamicResource Settings.MeetingSaveDir}" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="MeetingSavePathBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Settings.MeetingSaveDirHint}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="本地语音转文字（离线）" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,6"/>
                                <TextBlock Text="基于 whisper.cpp，本地离线将音频转写为文本。建议使用 tiny/base 量化模型。"
                                           Style="{StaticResource UiHint}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                                <TextBlock Text="whisper.cpp 可执行文件" Style="{StaticResource UiFieldLabel}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LocalSttExePathBox" Grid.Column="0" Style="{StaticResource UiTextBox}"/>
                                    <Button Grid.Column="2" Content="选择 EXE" Style="{StaticResource UiBtnSecondary}" MinWidth="92" Click="BrowseLocalSttExe_OnClick"/>
                                </Grid>

                                <TextBlock Text="模型文件路径" Style="{StaticResource UiFieldLabel}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LocalSttModelPathBox" Grid.Column="0" Style="{StaticResource UiTextBox}"/>
                                    <Button Grid.Column="2" Content="选择模型" Style="{StaticResource UiBtnSecondary}" MinWidth="92" Click="BrowseLocalSttModel_OnClick"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="语言" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="LocalSttLanguageBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                        <TextBlock Text="示例：zh / en / auto" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="线程数" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="LocalSttThreadsBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                        <TextBlock Text="建议 2~8" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="超时（秒）" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="LocalSttTimeoutBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                        <TextBlock Text="长音频可提高至 600+" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>

                                <CheckBox x:Name="LocalSttAutoPunctuationCheck"
                                          Content="保留标点（关闭后会做轻量去标点）"
                                          Style="{StaticResource SettingsCheckBox}"/>

                                <Button Content="校验本地 STT 配置"
                                        Style="{StaticResource UiBtnAccentBlue}"
                                        MinWidth="146"
                                        HorizontalAlignment="Left"
                                        Click="ValidateLocalStt_OnClick"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="文件与提醒">
                <ScrollViewer Style="{StaticResource SettingsTabScrollViewer}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.FileManager}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,6"/>
                                <TextBlock Text="{DynamicResource Settings.SandboxDir}" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="SandboxPathBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2"/>
                                <TextBlock Text="{DynamicResource Settings.SandboxDirHint}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.ReminderCenter}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{DynamicResource Settings.ReminderCenterHint}"
                                           Style="{StaticResource UiHint}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                <Border Background="{StaticResource BrushSurfaceMuted}"
                                        BorderBrush="{StaticResource BrushBorderSubtle}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,10"
                                        MaxWidth="420"
                                        HorizontalAlignment="Left">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Settings.TodoReminder}" Style="{StaticResource UiFieldLabel}"/>
                                        <CheckBox x:Name="TodoReminderCheck"
                                                  Content="{DynamicResource Settings.TodoReminderEnabled}"
                                                  Style="{StaticResource SettingsCheckBox}"/>
                                        <TextBlock Text="{DynamicResource Settings.TodoReminderInterval}" Style="{StaticResource UiFieldLabel}"/>
                                        <TextBox x:Name="TodoReminderIntervalBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,2" Width="90" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{DynamicResource Settings.TodoReminderHint}"
                                                   Style="{StaticResource UiHint}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <Button x:Name="OpenScheduledRemindersBtn"
                                                Content="{DynamicResource Settings.OpenScheduledReminders}"
                                                Style="{StaticResource UiBtnSecondary}"
                                                HorizontalAlignment="Left"
                                                Padding="14,8"
                                                Click="OpenScheduledReminders_OnClick"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="SkillsTab" Header="{DynamicResource Settings.Skills}">
                <views:SkillManagerView x:Name="SkillManagerPanel" Margin="0,10,6,0"/>
            </TabItem>

            <TabItem Header="关于更新">
                <ScrollViewer Style="{StaticResource SettingsTabScrollViewer}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings.About}" Style="{StaticResource UiSectionTitle}" Margin="0,0,0,8"/>
                                <TextBlock FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}" Text="DanceMonkey" FontSize="13"/>
                                <TextBlock x:Name="CurrentVersionText" Text="版本 --" Foreground="{StaticResource BrushTextSecondary}" FontSize="12.5"/>
                                <TextBlock Text="GitHub 仓库（owner/repo）" Style="{StaticResource UiFieldLabel}" Margin="0,12,0,0"/>
                                <TextBox x:Name="UpdateGitHubRepoBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,4"/>
                                <TextBlock Text="默认从该仓库的最新 Release 自动下载升级包。" Style="{StaticResource UiHint}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <TextBlock Text="升级包资源关键字" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="UpdateAssetKeywordBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,4"/>
                                <TextBlock Text="用于在 Release assets 中匹配 .zip 文件名，例如 win-x64。" Style="{StaticResource UiHint}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <TextBlock Text="在线升级清单 URL（可选，填写后优先使用）" Style="{StaticResource UiFieldLabel}"/>
                                <TextBox x:Name="UpdateManifestUrlBox" Style="{StaticResource UiTextBox}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button x:Name="UpdateBtn"
                                            Content="检查并更新"
                                            Style="{StaticResource UiBtnPrimary}"
                                            MinWidth="112"
                                            Click="UpdateBtn_OnClick"/>
                                </StackPanel>
                                <TextBlock x:Name="UpdateStatusText" Style="{StaticResource UiHint}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="{DynamicResource Settings.AboutDesc}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="12.5"
                                           TextWrapping="Wrap"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
