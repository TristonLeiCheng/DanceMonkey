<UserControl x:Class="DesktopAssistant.Views.SkillManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="SkillBtnPrimary" TargetType="Button" BasedOn="{StaticResource UiBtnPrimary}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>

        <Style x:Key="SkillBtnSecondary" TargetType="Button" BasedOn="{StaticResource UiBtnSecondary}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorderSubtle}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14,12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource SkillManager.Title}"
                               Style="{StaticResource UiSectionTitle}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource SkillManager.Lead}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="12.5"
                               LineHeight="19"/>
                    <TextBlock x:Name="PathText"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{StaticResource BrushTextMuted}"
                               FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            Margin="16,0,0,0">
                    <TextBlock x:Name="SkillCountText"
                               MinWidth="78"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="12"
                               Margin="0,0,10,0"/>
                    <Button x:Name="BtnRefresh"
                            MinWidth="80"
                            Margin="0,0,8,0"
                            Style="{StaticResource SkillBtnSecondary}"
                            Click="BtnRefresh_OnClick"
                            Content="{DynamicResource SkillManager.Refresh}"/>
                    <Button x:Name="BtnOpenFolder"
                            MinWidth="120"
                            Style="{StaticResource SkillBtnSecondary}"
                            Click="BtnOpenFolder_OnClick"
                            Content="{DynamicResource SkillManager.OpenFolder}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" MinHeight="360">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" MinWidth="240"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource SkillManager.Library}"
                               Style="{StaticResource UiFieldLabel}"
                               Margin="2,0,0,8"/>
                    <ListView x:Name="SkillList"
                              Grid.Row="1"
                              SelectionMode="Single"
                              BorderBrush="{StaticResource BrushBorderSubtle}"
                              BorderThickness="1"
                              Background="{StaticResource BrushSurfaceMuted}"
                              SelectionChanged="SkillList_OnSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,3">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="{StaticResource BrushTextPrimary}"/>
                                        <TextBlock Text="{Binding DisplaySummary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="11.5"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding MetadataLine}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource BrushTextMuted}"
                                                   FontSize="10.5"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Background="{StaticResource BrushSurfaceMuted}"
                            BorderBrush="{StaticResource BrushBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="SelectedNameText"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="13.5"/>
                            <TextBlock x:Name="SelectedDescriptionText"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="12"/>
                            <TextBlock x:Name="SelectedMetaText"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       FontFamily="Consolas"
                                       FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <TextBox x:Name="ContentBox"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12.5"
                             BorderBrush="{StaticResource BrushBorderSubtle}"
                             Background="{StaticResource BrushSurfaceMuted}"
                             Padding="10"/>
                    <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="False">
                        <TextBlock x:Name="StatusText"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="BtnDelete"
                                    MinWidth="84"
                                    IsEnabled="False"
                                    Style="{StaticResource SkillBtnSecondary}"
                                    Click="BtnDelete_OnClick"
                                    Content="{DynamicResource SkillManager.Delete}"/>
                            <Button x:Name="BtnSave"
                                    MinWidth="84"
                                    Margin="8,0,0,0"
                                    IsEnabled="False"
                                    Style="{StaticResource SkillBtnPrimary}"
                                    Click="BtnSave_OnClick"
                                    Content="{DynamicResource SkillManager.Save}"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="1.7*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource SkillManager.AddGroup}" Style="{StaticResource UiFieldLabel}"/>
                        <TextBox x:Name="NewNameBox"
                                 Height="30"
                                 Margin="0,4,0,6"
                                 BorderBrush="{StaticResource BrushBorderSubtle}"
                                 Padding="7,3"/>
                        <TextBlock Text="{DynamicResource SkillManager.NewDescriptionLabel}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                        <TextBox x:Name="NewDescriptionBox"
                                 Height="30"
                                 Margin="0,4,0,0"
                                 BorderBrush="{StaticResource BrushBorderSubtle}"
                                 Padding="7,3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource SkillManager.NewBodyLabel}" Style="{StaticResource UiHint}" TextWrapping="Wrap"/>
                        <TextBox x:Name="NewBodyBox"
                                 Height="82"
                                 Margin="0,4,0,8"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 BorderBrush="{StaticResource BrushBorderSubtle}"
                                 Padding="7"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnTemplate"
                                    MinWidth="100"
                                    Style="{StaticResource SkillBtnSecondary}"
                                    Click="BtnTemplate_OnClick"
                                    Content="{DynamicResource SkillManager.InsertTemplate}"/>
                            <Button x:Name="BtnAdd"
                                    MinWidth="100"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource SkillBtnPrimary}"
                                    Click="BtnAdd_OnClick"
                                    Content="{DynamicResource SkillManager.Add}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource SkillManager.ImportGroup}" Style="{StaticResource UiFieldLabel}"/>
                    <TextBlock Text="{DynamicResource SkillManager.ImportLead}"
                               TextWrapping="Wrap"
                               Style="{StaticResource UiHint}"
                               Margin="0,4,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ImportSourceBox"
                                 Height="30"
                                 BorderBrush="{StaticResource BrushBorderSubtle}"
                                 Padding="7,3"
                                 FontFamily="Consolas"/>
                        <Button Grid.Column="2"
                                x:Name="BtnBrowseImportFile"
                                MinWidth="72"
                                Style="{StaticResource SkillBtnSecondary}"
                                Click="BtnBrowseImportFile_OnClick"
                                Content="{DynamicResource SkillManager.BrowseFile}"/>
                        <Button Grid.Column="4"
                                x:Name="BtnBrowseImportFolder"
                                MinWidth="72"
                                Style="{StaticResource SkillBtnSecondary}"
                                Click="BtnBrowseImportFolder_OnClick"
                                Content="{DynamicResource SkillManager.BrowseFolder}"/>
                    </Grid>
                    <Button x:Name="BtnImport"
                            MinWidth="96"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Style="{StaticResource SkillBtnPrimary}"
                            Click="BtnImport_OnClick"
                            Content="{DynamicResource SkillManager.Import}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
