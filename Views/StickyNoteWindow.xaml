<Window x:Class="DesktopAssistant.Views.StickyNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="便签"
        Height="320" Width="300" MinWidth="240" MinHeight="200"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="#FFFAF3C8">
    <!-- #12 便签控件使用全局 Design Token 样式 -->
    <DockPanel>
        <Border x:Name="TitleBarBorder" DockPanel.Dock="Top" Background="#E8D88A" Padding="8,6">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleBlock" Grid.Column="0" Text="便签" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="#3D3510" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ComboBox x:Name="BgPresetCombo" Width="86" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                                  ToolTip="便签背景颜色"
                                  SelectionChanged="BgPresetCombo_OnSelectionChanged"/>
                        <Button x:Name="SaveDailyBtn" Content="存笔记" Style="{StaticResource UiBtnSecondary}"
                                FontSize="11" Padding="8,3" Margin="0,0,6,0"
                                ToolTip="保存到每日笔记目录（默认「文档\Daily Note」）：当天日期文件名；重名时为 -1、-2…"
                                Click="SaveDaily_OnClick" Cursor="Hand"/>
                        <CheckBox x:Name="TopmostCheck" Content="置顶" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                                  Checked="TopmostCheck_OnChanged" Unchecked="TopmostCheck_OnChanged"/>
                        <Button Content="×" Width="22" Height="22" Padding="0" FontSize="14" Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="Close_OnClick" Foreground="#5C4A20"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="待办" Style="{StaticResource UiBtnSecondary}"
                            FontSize="10" Padding="6,2" Margin="0,0,6,0" Cursor="Hand"
                            ToolTip="插入 Markdown 待办：- [ ] "
                            Click="InsertTodo_OnClick"/>
                    <Button Content="列表" Style="{StaticResource UiBtnSecondary}"
                            FontSize="10" Padding="6,2" Margin="0,0,6,0" Cursor="Hand"
                            ToolTip="插入无序列表：- "
                            Click="InsertBullet_OnClick"/>
                    <Button Content="有序" Style="{StaticResource UiBtnSecondary}"
                            FontSize="10" Padding="6,2" Cursor="Hand"
                            ToolTip="插入有序列表：1. "
                            Click="InsertOrdered_OnClick"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <TextBox x:Name="EditorBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 BorderThickness="0" Padding="10" FontSize="13" Background="Transparent"
                 TextChanged="EditorBox_OnTextChanged"/>
    </DockPanel>
</Window>
